@model List<Subscription>
@using System.Globalization

@{
    ViewData["Title"] = "Sonlandırılan Abonelikler";
}

<h3 class="mb-4">Sonlandırılan Aboneliklerim</h3>

@await Component.InvokeAsync("FlashMessage")

@if (!Model.Any())
{
    <div class="alert alert-secondary">Hiç sonlandırılmış aboneliğiniz bulunmamaktadır.</div>
}
else
{
    <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4">
        @foreach (var sub in Model)
        {
            <div class="col">
                <div class="card shadow-sm border-secondary">
                    <div class="card-body">
                        <h5 class="card-title">@sub.Name</h5>
                        <p class="card-text">
                            <strong>@sub.Price ₺</strong><br />
                            Yenileme Tarihi: @sub.RenewalDate.ToString("d MMMM yyyy", CultureInfo.CurrentCulture)<br />
                            Yenileme Sıklığı: @sub.RenewalPeriod gün
                        </p>

                        <div class="d-flex justify-content-between">
                            <a class="btn btn-warning btn-sm" asp-action="Update" asp-route-id="@sub.Id">Düzenle</a>
                            <form asp-action="Unarchive" asp-route-id="@sub.Id" method="post">
                                <button type="submit" class="btn btn-secondary btn-sm">Aktif Et</button>
                            </form>
                            <form asp-action="Delete" asp-route-id="@sub.Id" method="post">
                                <button type="submit" class="btn btn-outline-danger btn-sm">Tamamen Sil</button>
                            </form>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
}
