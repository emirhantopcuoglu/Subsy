@model List<Subscription>
@using System.Globalization

@{
    ViewData["Title"] = "Sonlandırılan Abonelikler";
}

<!-- Sayfa Başlığı -->
<h2 class="text-2xl font-semibold mb-6">Sonlandırılan Aboneliklerim</h2>

@await Component.InvokeAsync("FlashMessage")

@if (!Model.Any())
{
    <div class="flex items-start gap-3 bg-gray-100 border-l-4 border-gray-400 text-gray-600 rounded-xl p-4 shadow">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6 shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M13 16h-1v-4h-1m1-4h.01M12 2a10 10 0 100 20 10 10 0 000-20z" />
        </svg>
        <p>Hiç sonlandırılmış aboneliğiniz bulunmamaktadır.</p>
    </div>
}
else
{
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
        @foreach (var sub in Model)
        {
            <div class="bg-white border-2 border-gray-300 rounded-2xl shadow p-6 flex flex-col h-full">
                <!-- Başlık -->
                <h3 class="text-lg font-semibold mb-2 text-gray-700">@sub.Name</h3>

                <!-- Bilgiler -->
                <p class="text-sm text-gray-600 leading-relaxed mb-4">
                    <span class="font-medium text-gray-800">@sub.Price ₺</span><br />
                    Yenileme Tarihi: @sub.RenewalDate.ToString("d MMMM yyyy", CultureInfo.CurrentCulture)<br />
                    Yenileme Sıklığı: @sub.RenewalPeriod gün
                </p>

                <!-- Butonlar -->
                <div class="mt-auto flex flex-wrap gap-2">
                    <!-- Düzenle -->
                    <a asp-action="Update" asp-route-id="@sub.Id" class="inline-flex items-center gap-1 px-4 py-2 rounded-lg text-white bg-amber-500 hover:bg-amber-600 text-sm">
                        <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M15.232 5.232l3.536 3.536M9 11l6 6m2-13a2.121 2.121 0 113 3L5 21l-4 1 1-4L16 5z" />
                        </svg>
                        Düzenle
                    </a>

                    <!-- Aktif Et -->
                    <form asp-action="Unarchive" asp-route-id="@sub.Id" method="post">
                        <button type="submit" class="inline-flex items-center gap-1 px-4 py-2 rounded-lg text-white bg-slate-600 hover:bg-slate-700 text-sm">
                            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M4 4v6h6M20 20v-6h-6M4 14v6h6M20 10V4h-6" />
                            </svg>
                            Aktif Et
                        </button>
                    </form>

                    <!-- Sil -->
                    <form asp-action="Delete" asp-route-id="@sub.Id" method="post">
                        <button type="submit" class="inline-flex items-center gap-1 px-4 py-2 rounded-lg text-red-600 border border-red-600 hover:bg-red-600 hover:text-white transition text-sm">
                            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5-4h4m-4 0a1 1 0 00-1 1v1h6V4a1 1 0 00-1-1m-4 0h4" />
                            </svg>
                            Tamamen Sil
                        </button>
                    </form>
                </div>
            </div>
        }
    </div>
}
