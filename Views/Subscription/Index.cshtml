@model dynamic
@using System.Globalization
@{
    ViewData["Title"] = "Dashboard";
    var upcomingList = ViewBag.Upcoming as List<Subscription> ?? new();
}

<h2 class="fw-semibold mb-4"><i class="bi bi-bar-chart-fill me-2 text-primary"></i>Genel Durum</h2>

@await Component.InvokeAsync("FlashMessage")

<section class="bg-light rounded-4 p-4 shadow-sm mb-5">
    <div class="row g-4">
        <div class="col-md-3">
            <div class="card border-0 shadow-sm rounded-4 p-3 bg-white h-100">
                <div class="d-flex align-items-center">
                    <div class="me-3 bg-primary text-white rounded-circle d-flex justify-content-center align-items-center" style="width:45px; height:45px;">
                        <i class="bi bi-check2-circle fs-4"></i>
                    </div>
                    <div>
                        <small class="text-muted">Aktif Abonelik</small>
                        <h5 class="fw-bold">@ViewBag.ActiveCount</h5>
                        <p class="small text-muted mb-0">Yenileme tarihi geçmemiş</p>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card border-0 shadow-sm rounded-4 p-3 bg-white h-100">
                <div class="d-flex align-items-center">
                    <div class="me-3 bg-warning text-white rounded-circle d-flex justify-content-center align-items-center" style="width:45px; height:45px;">
                        <i class="bi bi-exclamation-triangle-fill fs-4"></i>
                    </div>
                    <div>
                        <small class="text-muted">Bugün Ödeme</small>
                        <h5 class="fw-bold">@ViewBag.TodayDueCount</h5>
                        <p class="small text-muted mb-0">Bugüne denk gelenler</p>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card border-0 shadow-sm rounded-4 p-3 bg-white h-100">
                <div class="d-flex align-items-center">
                    <div class="me-3 bg-success text-white rounded-circle d-flex justify-content-center align-items-center" style="width:45px; height:45px;">
                        <i class="bi bi-cash-coin fs-4"></i>
                    </div>
                    <div>
                        <small class="text-muted">Bu Ay Harcama</small>
                        <h5 class="fw-bold">@($"{ViewBag.TotalThisMonth:0.00}") ₺</h5>
                        <p class="small text-muted mb-0">Toplam ödeme</p>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card border-0 shadow-sm rounded-4 p-3 bg-white h-100">
                <div class="d-flex align-items-center">
                    <div class="me-3 bg-info text-white rounded-circle d-flex justify-content-center align-items-center" style="width:45px; height:45px;">
                        <i class="bi bi-calendar3-event-fill fs-4"></i>
                    </div>
                    <div>
                        <small class="text-muted">Yaklaşan Ödeme</small>
                        <h5 class="fw-bold">@upcomingList.Count</h5>
                        <p class="small text-muted mb-0">3 gün içinde</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

@if (upcomingList.Any())
{
    <div class="alert alert-warning border-0 rounded-4 shadow-sm px-4 py-3">
        <i class="bi bi-bell-fill me-2"></i>
        <strong>Yaklaşan Ödemeler:</strong>
        <ul class="mt-2 mb-0">
            @foreach (var item in upcomingList)
            {
                <li>
                    <strong>@item.Name</strong> – @item.RenewalDate.ToString("d MMMM yyyy", CultureInfo.CurrentCulture)
                </li>
            }
        </ul>
    </div>
}
else
{
    <div class="alert alert-light border-start border-4 border-info mt-4 shadow-sm rounded-3">
        <i class="bi bi-info-circle me-2"></i>
        Şu anda 3 gün içinde ödeme günü gelen bir aboneliğiniz bulunmamaktadır.
    </div>
}

<section class="mt-5">
    <h5 class="fw-semibold mb-3"><i class="bi bi-lightbulb-fill me-2 text-warning"></i>Bugün ne yapmak istersiniz?</h5>
    <div class="d-flex flex-wrap gap-3">
        <a class="btn btn-outline-primary rounded-pill" asp-controller="Subscription" asp-action="Create">
            <i class="bi bi-plus-circle me-1"></i> Yeni Abonelik
        </a>
        <a class="btn btn-outline-secondary rounded-pill" asp-controller="Subscription" asp-action="Active">
            <i class="bi bi-layers me-1"></i> Aktif Aboneliklerim
        </a>
        <a class="btn btn-outline-warning rounded-pill" asp-controller="Subscription" asp-action="Due">
            <i class="bi bi-alarm-fill me-1"></i> Ödeme Günü Gelenler
        </a>
    </div>
</section>

<section class="mt-5">
    <div class="card p-4 text-center shadow-sm rounded-4 text-muted">
        <i class="bi bi-graph-up-arrow fs-1 mb-3"></i>
        <p class="mb-0">Yakında burada abonelik harcamalarınıza dair grafikler olacak.</p>
    </div>
</section>
