@model Subsy.Web.Models.DashboardViewModel
@using System.Globalization
@using System.Text.Json
@using Subsy.Application.Common

@{
    ViewData["Title"] = "Dashboard";
    var upcomingList = Model.Upcoming ?? new();
    var tr = new CultureInfo("tr-TR");

    var trendLabels = JsonSerializer.Serialize(Model.SixMonthTrend.Select(p => p.Label));
    var trendValues = JsonSerializer.Serialize(Model.SixMonthTrend.Select(p => p.Amount));

    var totalMonthly = Model.PaidThisMonth + Model.RemainingThisMonth;
    var paidPct = totalMonthly > 0 ? (double)Model.PaidThisMonth / (double)totalMonthly * 100 : 0;
}

<div class="stat-grid">
    <div class="stat-card">
        <div class="stat-icon" style="background:oklch(0.52 0.20 260 / 0.12);">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="oklch(0.52 0.20 260)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M8 6h13M8 12h13M8 18h13M3 6h.01M3 12h.01M3 18h.01"/>
            </svg>
        </div>
        <div class="stat-value" style="color:var(--accent);">@Model.ActiveCount</div>
        <div class="stat-label" style="margin-top:4px;">Aktif Abonelik</div>
        <div class="stat-sub">Toplam aktif</div>
    </div>

    <div class="stat-card">
        <div class="stat-icon" style="background:oklch(0.52 0.20 20 / 0.12);">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="var(--danger)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M12 22a10 10 0 1 0 0-20 10 10 0 0 0 0 20"/><path d="M12 6v6l4 2"/>
            </svg>
        </div>
        <div class="stat-value" style="color:var(--danger);">@Model.TodayDueCount</div>
        <div class="stat-label" style="margin-top:4px;">Ödeme Günü</div>
        <div class="stat-sub">Bekleyen ödeme</div>
    </div>

    <div class="stat-card">
        <div class="stat-icon" style="background:oklch(0.55 0.18 290 / 0.12);">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="oklch(0.55 0.18 290)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <rect x="3" y="4" width="18" height="18" rx="2"/><path d="M16 2v4M8 2v4M3 10h18"/>
            </svg>
        </div>
        <div class="stat-value" style="color:oklch(0.55 0.18 290);">@Model.YearlyCost.ToString("C0", tr)</div>
        <div class="stat-label" style="margin-top:4px;">Yıllık Tahmin</div>
        <div class="stat-sub">Aylık eşdeğer × 12</div>
    </div>

    <div class="stat-card">
        <div class="stat-icon" style="background:oklch(0.62 0.16 55 / 0.12);">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="var(--warning)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"/><path d="M13.73 21a2 2 0 0 1-3.46 0"/>
            </svg>
        </div>
        <div class="stat-value" style="color:var(--warning);">@upcomingList.Count</div>
        <div class="stat-label" style="margin-top:4px;">Yaklaşan Ödeme</div>
        <div class="stat-sub">3 gün içinde</div>
    </div>
</div>

<div style="display:grid; grid-template-columns:1fr 1fr; gap:14px; margin-bottom:24px;">
    <div class="stat-card">
        <div style="display:flex; align-items:center; gap:8px; margin-bottom:12px;">
            <div class="stat-icon" style="background:oklch(0.52 0.16 152 / 0.12); flex-shrink:0;">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="var(--success)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M12 22V12m0 0l-4 4m4-4l4 4"/><circle cx="12" cy="5" r="2"/>
                </svg>
            </div>
            <div class="stat-label" style="margin:0;">Bu Ay Özeti</div>
            <div style="margin-left:auto; font-size:14px; font-weight:700; color:var(--text-primary);">@totalMonthly.ToString("C0", tr)</div>
        </div>
        <div style="display:flex; justify-content:space-between; margin-bottom:8px;">
            <span style="font-size:11px; color:var(--success); font-weight:600;">Ödendi: @Model.PaidThisMonth.ToString("C0", tr)</span>
            <span style="font-size:11px; color:var(--text-secondary); font-weight:600;">Kalan: @Model.RemainingThisMonth.ToString("C0", tr)</span>
        </div>
        <div class="progress-track" style="height:8px; margin-bottom:8px;">
            <div class="progress-fill" style="width:@paidPct.ToString("F0")%; background:var(--success);"></div>
        </div>
        <div style="font-size:11px; color:var(--text-muted);">
            @if (totalMonthly == 0)
            {
                <span>Bu ay ödeme planı yok</span>
            }
            else
            {
                <span>%@paidPct.ToString("F0") ödendi</span>
            }
        </div>
    </div>

    <div class="stat-card">
        <div style="display:flex; align-items:center; gap:8px; margin-bottom:10px;">
            <div class="stat-icon" style="background:oklch(0.52 0.16 152 / 0.12); flex-shrink:0;">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="var(--success)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/>
                </svg>
            </div>
            <div class="stat-label" style="margin:0;">6 Aylık Trend</div>
        </div>
        <div style="height:60px; position:relative;">
            <canvas id="sparklineChart"></canvas>
        </div>
    </div>
</div>

@if (Model.TodayDueCount > 0)
{
    <div class="alert alert-warning" style="margin-bottom:20px;">
        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="flex-shrink:0; margin-top:1px;">
            <path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"/><path d="M13.73 21a2 2 0 0 1-3.46 0"/>
        </svg>
        <div>
            <strong>@Model.TodayDueCount abonelik</strong> ödeme bekliyor.
            <a asp-controller="Subscription" asp-action="Due" style="margin-left:8px; font-weight:600; color:inherit; text-decoration:underline;">Görüntüle →</a>
        </div>
    </div>
}

<div style="display:grid; grid-template-columns:1fr 340px; gap:16px;">
    <div class="card">
        <div style="padding:16px 18px; border-bottom:1px solid var(--border); display:flex; align-items:center; justify-content:space-between;">
            <div class="section-title">Yaklaşan Ödemeler</div>
            <a asp-controller="Subscription" asp-action="Active" class="btn btn-ghost btn-sm">Tümünü Gör</a>
        </div>
        @if (!upcomingList.Any())
        {
            <div class="empty" style="padding:40px 20px;">
                <div class="empty-icon">
                    <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M5 13l4 4L19 7"/>
                    </svg>
                </div>
                <div class="empty-text">3 gün içinde ödeme günü gelen abonelik yok</div>
            </div>
        }
        else
        {
            <table class="table">
                <thead>
                    <tr>
                        <th>Abonelik</th>
                        <th>Tutar</th>
                        <th>Yenileme</th>
                        <th>Durum</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in upcomingList)
                    {
                        var days = (item.RenewalDate - DateTime.Today).Days;
                        var isOver = days <= 0;
                        var faviconUrl = ServiceRegistry.GetFaviconUrl(item.Name);
                        <tr>
                            <td>
                                <div style="display:flex; align-items:center; gap:10px;">
                                    @if (faviconUrl is not null)
                                    {
                                        <img src="@faviconUrl" alt="@item.Name" class="sub-favicon" onerror="this.style.display='none';this.nextElementSibling.style.display='flex';" />
                                        <div style="width:28px; height:28px; border-radius:7px; background:var(--accent); display:none; align-items:center; justify-content:center; font-size:12px; font-weight:700; color:#fff; flex-shrink:0;">
                                            @item.Name[0].ToString().ToUpper()
                                        </div>
                                    }
                                    else
                                    {
                                        <div style="width:28px; height:28px; border-radius:7px; background:var(--accent); display:flex; align-items:center; justify-content:center; font-size:12px; font-weight:700; color:#fff; flex-shrink:0;">
                                            @item.Name[0].ToString().ToUpper()
                                        </div>
                                    }
                                    <span style="font-weight:500; font-size:13px;">@item.Name</span>
                                </div>
                            </td>
                            <td style="font-weight:600; font-size:13px;">@item.Price.ToString("N2", tr) @item.Currency</td>
                            <td style="font-size:12px; color:var(--text-secondary);">@item.RenewalDate.ToString("d MMM yyyy", tr)</td>
                            <td>
                                @if (isOver)
                                {
                                    <span class="chip chip-red">Gecikmiş</span>
                                }
                                else if (days <= 1)
                                {
                                    <span class="chip chip-red">Yarın</span>
                                }
                                else
                                {
                                    <span class="chip chip-blue">@days g kaldı</span>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }
    </div>

    <div class="card card-p">
        <div class="section-title" style="margin-bottom:16px;">Hızlı Erişim</div>
        <div style="display:flex; flex-direction:column; gap:8px;">
            <a asp-controller="Subscription" asp-action="Create" class="btn btn-primary" style="justify-content:center;">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 5v14M5 12h14"/></svg>
                Yeni Abonelik Ekle
            </a>
            <a asp-controller="Subscription" asp-action="Active" class="btn btn-ghost" style="justify-content:center;">
                Aktif Abonelikler
            </a>
            <a asp-controller="Subscription" asp-action="Due" class="btn btn-ghost" style="justify-content:center;">
                Ödeme Günü Gelenler
            </a>
            <a asp-controller="Finance" asp-action="Dashboard" class="btn btn-ghost" style="justify-content:center;">
                Finansal Analiz
            </a>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        const sparkLabels = @Html.Raw(trendLabels);
        const sparkValues = @Html.Raw(trendValues);

        new Chart(document.getElementById('sparklineChart'), {
            type: 'line',
            data: {
                labels: sparkLabels,
                datasets: [{
                    data: sparkValues,
                    borderColor: 'var(--success)',
                    backgroundColor: 'oklch(0.52 0.16 152 / 0.12)',
                    borderWidth: 2,
                    pointRadius: 3,
                    pointHoverRadius: 4,
                    fill: true,
                    tension: 0.4
                }]
            },
            options: {
                responsive: true, maintainAspectRatio: false,
                plugins: { legend: { display: false }, tooltip: {
                    callbacks: { label: ctx => ctx.parsed.y.toLocaleString('tr-TR', { style: 'currency', currency: 'TRY' }) }
                }},
                scales: {
                    x: { display: false },
                    y: { display: false }
                }
            }
        });
    </script>
}
