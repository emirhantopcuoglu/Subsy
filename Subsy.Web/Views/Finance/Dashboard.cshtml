@model FinanceViewModel
@using System.Globalization
@using System.Text.Json

@{
    ViewData["Title"] = "Finansal Analiz";
    var tr = new CultureInfo("tr-TR");

    var labelsJson = JsonSerializer.Serialize(Model.GroupedByService.Select(x => x.SubscriptionName));
    var dataJson = JsonSerializer.Serialize(Model.GroupedByService.Select(x => x.TotalCost));
}

<div class="pt-6 max-w-screen-2xl mx-auto space-y-10">
    <div class="flex items-center justify-between gap-4">
        <h1 class="text-3xl font-bold text-gray-800">📊 Finansal Analiz</h1>
        <span class="text-sm text-gray-500">
            (Not: Ödeme geçmişi yoksa değerler “tahmini/planlı” hesaplanır.)
        </span>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-4 gap-6">
        <div class="bg-white p-5 rounded-2xl shadow">
            <p class="text-sm text-gray-500">Aylık Tahmini Maliyet</p>
            <p class="text-2xl font-bold text-indigo-600">@Model.TotalMonthlyCost.ToString("C", tr)</p>
            <p class="text-xs text-gray-400 mt-1">Aboneliklerin aylık eşdeğeri</p>
        </div>

        <div class="bg-white p-5 rounded-2xl shadow">
            <p class="text-sm text-gray-500">Toplam Abonelik Maliyeti</p>
            <p class="text-2xl font-bold text-green-600">@Model.AllTimeSpending.ToString("C", tr)</p>
            <p class="text-xs text-gray-400 mt-1">Aktif abonelik fiyatlarının toplamı</p>
        </div>

        <div class="bg-white p-5 rounded-2xl shadow">
            <p class="text-sm text-gray-500">Aktif Abonelik Sayısı</p>
            <p class="text-2xl font-bold text-blue-600">@Model.SubscriptionCount</p>
            <p class="text-xs text-gray-400 mt-1">Sonlandırılmamış</p>
        </div>

        <div class="bg-white p-5 rounded-2xl shadow">
            <p class="text-sm text-gray-500">En Çok Maliyet</p>

            @if (Model.TopSpendingService is null)
            {
                <p class="text-gray-400 text-sm mt-2">Henüz yeterli veri yok</p>
            }
            else
            {
                <p class="text-xl font-semibold text-rose-600">
                    @Model.TopSpendingService.SubscriptionName
                </p>
                <p class="text-lg">
                    @Model.TopSpendingService.TotalCost.ToString("C", tr)
                </p>
                <p class="text-xs text-gray-400 mt-1">
                    Aylık eşdeğer bazında
                </p>
            }
        </div>
    </div>

    <div class="bg-white rounded-2xl shadow p-6 grid grid-cols-1 lg:grid-cols-2 gap-10">
        <div>
            <h2 class="text-xl font-semibold mb-4 text-gray-700">📈 Servis Bazlı Dağılım (Pasta)</h2>
            <canvas id="pieChart"></canvas>
        </div>
        <div>
            <h2 class="text-xl font-semibold mb-4 text-gray-700">📊 Servis Bazlı Maliyet (Çubuk)</h2>
            <canvas id="barChart"></canvas>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        const labels = @Html.Raw(labelsJson);
        const values = @Html.Raw(dataJson);

        const colors = [
            '#4F46E5','#7C3AED','#EC4899','#10B981','#F59E0B',
            '#3B82F6','#E11D48','#22C55E','#F97316','#8B5CF6'
        ];

        const fmtTRY = (v) => v.toLocaleString('tr-TR', { style: 'currency', currency: 'TRY' });

        const pieCanvas = document.getElementById('pieChart');
        new Chart(pieCanvas, {
            type: 'pie',
            data: {
                labels,
                datasets: [{
                    data: values,
                    backgroundColor: colors.slice(0, values.length),
                    borderColor: '#fff',
                    borderWidth: 2,
                }]
            },
            options: {
                responsive: true,
                plugins: {
                    legend: { position: 'bottom' },
                    tooltip: {
                        callbacks: {
                            label: (ctx) => `${ctx.label}: ${fmtTRY(ctx.parsed || 0)}`
                        }
                    }
                }
            }
        });

        const barCanvas = document.getElementById('barChart');
        new Chart(barCanvas, {
            type: 'bar',
            data: {
                labels,
                datasets: [{
                    label: 'Aylık Maliyet',
                    data: values,
                    backgroundColor: colors.slice(0, values.length),
                    borderWidth: 1
                }]
            },
            options: {
                responsive: true,
                scales: {
                    y: {
                        beginAtZero: true,
                        ticks: { callback: (val) => fmtTRY(val) }
                    }
                },
                plugins: {
                    legend: { display: false },
                    tooltip: { callbacks: { label: (ctx) => fmtTRY(ctx.parsed.y) } }
                }
            }
        });
    </script>
}