@model FinanceViewModel
@using System.Globalization
@using System.Text.Json

@{
    ViewData["Title"] = "Finansal Analiz";
    var tr = new CultureInfo("tr-TR");

    var serviceLabels = JsonSerializer.Serialize(Model.GroupedByService.Select(x => x.SubscriptionName));
    var serviceData   = JsonSerializer.Serialize(Model.GroupedByService.Select(x => x.TotalCost));

    var catLabels = JsonSerializer.Serialize(Model.GroupedByCategory.Select(x => x.CategoryName));
    var catData   = JsonSerializer.Serialize(Model.GroupedByCategory.Select(x => x.TotalCost));

    var trendLabels = JsonSerializer.Serialize(Model.TwelveMonthTrend.Select(x => x.Label));
    var trendData   = JsonSerializer.Serialize(Model.TwelveMonthTrend.Select(x => x.Amount));

    var planLabels = JsonSerializer.Serialize(new[] { "Aylık Planlar", "Yıllık Planlar" });
    var planData   = JsonSerializer.Serialize(new[] { Model.MonthlyPlanTotal, Model.YearlyPlanTotal });
}

@* ── Stat cards ──────────────────────────────────────────── *@
<div class="stat-grid" style="margin-bottom:20px;">
    <div class="stat-card">
        <div class="stat-label">Aylık Tahmini Maliyet</div>
        <div class="stat-value" style="font-size:20px; color:var(--accent); margin-top:4px;">@Model.TotalMonthlyCost.ToString("C0", tr)</div>
        <div class="stat-sub">Aboneliklerin aylık eşdeğeri</div>
    </div>
    <div class="stat-card">
        <div class="stat-label">Toplam Abonelik Maliyeti</div>
        <div class="stat-value" style="font-size:20px; color:var(--success); margin-top:4px;">@Model.AllTimeSpending.ToString("C0", tr)</div>
        <div class="stat-sub">Aktif abonelik fiyatlarının toplamı</div>
    </div>
    <div class="stat-card">
        <div class="stat-label">Aktif Abonelik Sayısı</div>
        <div class="stat-value" style="font-size:20px; color:var(--accent); margin-top:4px;">@Model.SubscriptionCount</div>
        <div class="stat-sub">Sonlandırılmamış</div>
    </div>
    <div class="stat-card">
        <div class="stat-label">En Çok Maliyet</div>
        @if (Model.TopSpendingService is null)
        {
            <div class="stat-value" style="font-size:14px; color:var(--text-muted); margin-top:4px;">Henüz veri yok</div>
        }
        else
        {
            <div class="stat-value" style="font-size:18px; color:var(--danger); margin-top:4px;">@Model.TopSpendingService.SubscriptionName</div>
            <div class="stat-sub">@Model.TopSpendingService.TotalCost.ToString("C0", tr) aylık</div>
        }
    </div>
</div>

@* ── Yıllık vs aylık plan kartları ───────────────────────── *@
<div style="display:grid; grid-template-columns:1fr 1fr; gap:14px; margin-bottom:20px;">
    <div class="stat-card" style="display:flex; align-items:center; gap:16px;">
        <div class="stat-icon" style="background:oklch(0.52 0.20 260 / 0.12); width:44px; height:44px; flex-shrink:0;">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="oklch(0.52 0.20 260)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <rect x="3" y="4" width="18" height="18" rx="2"/><path d="M16 2v4M8 2v4M3 10h18"/>
            </svg>
        </div>
        <div>
            <div class="stat-label">Yıllık Plan Toplamı (Aylık Eşdeğer)</div>
            <div class="stat-value" style="font-size:20px; color:oklch(0.52 0.20 260); margin-top:2px;">@Model.YearlyPlanTotal.ToString("C0", tr)</div>
            <div class="stat-sub">≥ 300 günlük abonelikler</div>
        </div>
    </div>
    <div class="stat-card" style="display:flex; align-items:center; gap:16px;">
        <div class="stat-icon" style="background:oklch(0.62 0.16 55 / 0.12); width:44px; height:44px; flex-shrink:0;">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="var(--warning)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/>
            </svg>
        </div>
        <div>
            <div class="stat-label">Aylık Plan Toplamı</div>
            <div class="stat-value" style="font-size:20px; color:var(--warning); margin-top:2px;">@Model.MonthlyPlanTotal.ToString("C0", tr)</div>
            <div class="stat-sub">&lt; 300 günlük abonelikler</div>
        </div>
    </div>
</div>

@* ── 12 aylık trend ───────────────────────────────────────── *@
<div class="card card-p" style="margin-bottom:20px;">
    <div class="section-title" style="margin-bottom:4px;">12 Aylık Harcama Trendi</div>
    <div style="font-size:12px; color:var(--text-secondary); margin-bottom:16px;">Son 12 ay gerçekleşen abonelik ödemeleri</div>
    <div class="chart-wrap" style="height:220px;"><canvas id="trendChart"></canvas></div>
</div>

@* ── Servis dağılımı + Kategori pasta ────────────────────── *@
<div class="finance-grid" style="margin-bottom:20px;">
    <div class="card card-p">
        <div class="section-title" style="margin-bottom:16px;">Servis Dağılımı</div>
        <div class="chart-wrap"><canvas id="pieChart"></canvas></div>
    </div>
    <div class="card card-p">
        <div class="section-title" style="margin-bottom:16px;">Kategori Dağılımı</div>
        @if (!Model.GroupedByCategory.Any())
        {
            <div class="empty" style="padding:60px 0;">
                <div class="empty-text">Kategorize edilmiş abonelik yok</div>
            </div>
        }
        else
        {
            <div class="chart-wrap"><canvas id="categoryChart"></canvas></div>
        }
    </div>
</div>

@* ── Aylık maliyet karşılaştırması + Yıllık vs Aylık ─────── *@
<div class="finance-grid">
    <div class="card card-p">
        <div class="section-title" style="margin-bottom:16px;">Aylık Maliyet Karşılaştırması</div>
        <div class="chart-wrap"><canvas id="barChart"></canvas></div>
    </div>
    <div class="card card-p">
        <div class="section-title" style="margin-bottom:16px;">Yıllık vs Aylık Plan</div>
        <div class="chart-wrap"><canvas id="planChart"></canvas></div>
        @if (Model.YearlyPlanTotal + Model.MonthlyPlanTotal > 0)
        {
            <div style="margin-top:16px; display:flex; flex-direction:column; gap:8px;">
                @{
                    var total = Model.YearlyPlanTotal + Model.MonthlyPlanTotal;
                    var monthlyPct = total > 0 ? (double)Model.MonthlyPlanTotal / (double)total * 100 : 0;
                    var yearlyPct = total > 0 ? (double)Model.YearlyPlanTotal / (double)total * 100 : 0;
                }
                <div style="display:flex; align-items:center; justify-content:space-between;">
                    <span style="font-size:12px; color:var(--text-secondary);">Aylık planlar</span>
                    <span style="font-size:12px; font-weight:600;">%@monthlyPct.ToString("F0")</span>
                </div>
                <div class="progress-track" style="height:6px;">
                    <div class="progress-fill" style="width:@monthlyPct.ToString("F0")%; background:var(--warning);"></div>
                </div>
                <div style="display:flex; align-items:center; justify-content:space-between;">
                    <span style="font-size:12px; color:var(--text-secondary);">Yıllık planlar</span>
                    <span style="font-size:12px; font-weight:600;">%@yearlyPct.ToString("F0")</span>
                </div>
                <div class="progress-track" style="height:6px;">
                    <div class="progress-fill" style="width:@yearlyPct.ToString("F0")%; background:oklch(0.52 0.20 260);"></div>
                </div>
            </div>
        }
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        const colors = ['#4f46e5','#0891b2','#059669','#d97706','#dc2626','#7c3aed','#0d9488','#db2777','#f59e0b','#3b82f6','#10b981','#f97316'];
        const fmtTRY = (v) => v.toLocaleString('tr-TR', { style: 'currency', currency: 'TRY' });

        // Servis dağılımı doughnut
        const serviceLabels = @Html.Raw(serviceLabels);
        const serviceData   = @Html.Raw(serviceData);

        new Chart(document.getElementById('pieChart'), {
            type: 'doughnut',
            data: {
                labels: serviceLabels,
                datasets: [{ data: serviceData, backgroundColor: colors.slice(0, serviceData.length), borderWidth: 2, borderColor: '#fff' }]
            },
            options: {
                responsive: true, maintainAspectRatio: false,
                plugins: {
                    legend: { position: 'bottom', labels: { font: { family: 'DM Sans', size: 11 }, padding: 12, boxWidth: 10 } },
                    tooltip: { callbacks: { label: ctx => `${ctx.label}: ${fmtTRY(ctx.parsed || 0)}` } }
                }
            }
        });

        // Aylık maliyet bar
        new Chart(document.getElementById('barChart'), {
            type: 'bar',
            data: {
                labels: serviceLabels,
                datasets: [{ data: serviceData, backgroundColor: colors.slice(0, serviceData.length), borderRadius: 5, borderSkipped: false }]
            },
            options: {
                responsive: true, maintainAspectRatio: false,
                plugins: {
                    legend: { display: false },
                    tooltip: { callbacks: { label: ctx => fmtTRY(ctx.parsed.y) } }
                },
                scales: {
                    y: { beginAtZero: true, grid: { color: 'var(--border)' }, ticks: { font: { family: 'DM Sans', size: 11 }, callback: v => fmtTRY(v) } },
                    x: { grid: { display: false }, ticks: { font: { family: 'DM Sans', size: 11 } } }
                }
            }
        });

        // Kategori doughnut
        const catLabels = @Html.Raw(catLabels);
        const catData   = @Html.Raw(catData);

        if (catData.length > 0) {
            new Chart(document.getElementById('categoryChart'), {
                type: 'doughnut',
                data: {
                    labels: catLabels,
                    datasets: [{ data: catData, backgroundColor: colors.slice(0, catData.length), borderWidth: 2, borderColor: '#fff' }]
                },
                options: {
                    responsive: true, maintainAspectRatio: false,
                    plugins: {
                        legend: { position: 'bottom', labels: { font: { family: 'DM Sans', size: 11 }, padding: 12, boxWidth: 10 } },
                        tooltip: { callbacks: { label: ctx => `${ctx.label}: ${fmtTRY(ctx.parsed || 0)}` } }
                    }
                }
            });
        }

        // 12 aylık trend line chart
        const trendLabels = @Html.Raw(trendLabels);
        const trendData   = @Html.Raw(trendData);

        new Chart(document.getElementById('trendChart'), {
            type: 'line',
            data: {
                labels: trendLabels,
                datasets: [{
                    label: 'Aylık Harcama',
                    data: trendData,
                    borderColor: '#4f46e5',
                    backgroundColor: 'rgba(79,70,229,0.08)',
                    borderWidth: 2.5,
                    pointRadius: 4,
                    pointHoverRadius: 6,
                    fill: true,
                    tension: 0.4
                }]
            },
            options: {
                responsive: true, maintainAspectRatio: false,
                plugins: {
                    legend: { display: false },
                    tooltip: { callbacks: { label: ctx => fmtTRY(ctx.parsed.y) } }
                },
                scales: {
                    y: { beginAtZero: true, grid: { color: 'var(--border)' }, ticks: { font: { family: 'DM Sans', size: 11 }, callback: v => fmtTRY(v) } },
                    x: { grid: { display: false }, ticks: { font: { family: 'DM Sans', size: 11 } } }
                }
            }
        });

        // Yıllık vs Aylık plan doughnut
        const planLabels = @Html.Raw(planLabels);
        const planData   = @Html.Raw(planData);

        new Chart(document.getElementById('planChart'), {
            type: 'doughnut',
            data: {
                labels: planLabels,
                datasets: [{ data: planData, backgroundColor: ['#d97706', '#4f46e5'], borderWidth: 2, borderColor: '#fff' }]
            },
            options: {
                responsive: true, maintainAspectRatio: false,
                cutout: '65%',
                plugins: {
                    legend: { position: 'bottom', labels: { font: { family: 'DM Sans', size: 11 }, padding: 12, boxWidth: 10 } },
                    tooltip: { callbacks: { label: ctx => `${ctx.label}: ${fmtTRY(ctx.parsed || 0)}` } }
                }
            }
        });
    </script>
}
