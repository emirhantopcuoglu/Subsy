@model FinanceViewModel

@{
    ViewBag.Title = "Finansal Analiz";

    var labels = Model.GroupedByService.Select(x => x.SubscriptionName).ToList();
    var data = Model.GroupedByService.Select(x => x.TotalCost).ToList();

    string labelsString = string.Join(",", labels.Select(l => $"'{l}'"));
    string dataString = string.Join(",", data);
}

<div class="pl-64 pt-8 px-6 max-w-screen-2xl mx-auto space-y-10">
    <h1 class="text-3xl font-bold text-gray-800 mb-6">📊 Finansal Analiz</h1>

    <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-4 gap-6">
        <div class="bg-white p-5 rounded-2xl shadow">
            <p class="text-sm text-gray-500">Bu Ayki Harcama</p>
            <p class="text-2xl font-bold text-indigo-600">@Model.TotalMonthlyCost.ToString("C")</p>
        </div>
        <div class="bg-white p-5 rounded-2xl shadow">
            <p class="text-sm text-gray-500">Toplam Harcama</p>
            <p class="text-2xl font-bold text-green-600">@Model.AllTimeSpending.ToString("C")</p>
        </div>
        <div class="bg-white p-5 rounded-2xl shadow">
            <p class="text-sm text-gray-500">Aktif Abonelik Sayısı</p>
            <p class="text-2xl font-bold text-blue-600">@Model.SubscriptionCount</p>
        </div>
        <div class="bg-white p-5 rounded-2xl shadow">
            <p class="text-sm text-gray-500">En Çok Harcama</p>
            <p class="text-xl font-semibold text-rose-600">@Model.TopSpendingService?.SubscriptionName ?? "-"</p>
            <p class="text-lg">@Model.TopSpendingService?.TotalCost.ToString("C") ?? "-"</p>
        </div>
    </div>

    <div class="bg-white rounded-2xl shadow p-6 grid grid-cols-1 md:grid-cols-2 gap-10">
        <div>
            <h2 class="text-xl font-semibold mb-4 text-gray-700">📈 Servis Bazlı Harcama Dağılımı (Pasta Grafiği)</h2>
            <canvas id="pieChart" data-labels="@labelsString" data-values="@dataString"></canvas>
        </div>
        <div>
            <h2 class="text-xl font-semibold mb-4 text-gray-700">📊 Servis Bazlı Harcama (Çubuk Grafik)</h2>
            <canvas id="barChart" data-labels="@labelsString" data-values="@dataString"></canvas>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        function parseData(canvas) {
            const labels = canvas.dataset.labels.split(",").map(l => l.trim().replace(/^'|'$/g, ""));
            const values = canvas.dataset.values.split(",").map(v => Number(v.trim()));
            return { labels, values };
        }

        const colors = [
            '#4F46E5', // indigo-600
            '#7C3AED', // purple-700
            '#EC4899', // pink-500
            '#10B981', // green-500
            '#F59E0B', // amber-500
            '#3B82F6', // blue-500
            '#E11D48', // rose-600
            '#22C55E', // green-600
            '#F97316', // orange-500
            '#8B5CF6'  // violet-500
        ];

        // Pasta Grafiği
        const pieCanvas = document.getElementById('pieChart');
        const pieData = parseData(pieCanvas);

        new Chart(pieCanvas, {
            type: 'pie',
            data: {
                labels: pieData.labels,
                datasets: [{
                    data: pieData.values,
                    backgroundColor: colors.slice(0, pieData.values.length),
                    borderColor: '#fff',
                    borderWidth: 2,
                }]
            },
            options: {
                responsive: true,
                plugins: {
                    legend: { position: 'bottom' },
                    tooltip: {
                        callbacks: {
                            label: ctx => {
                                let label = ctx.label || '';
                                let val = ctx.parsed || 0;
                                return `${label}: ${val.toLocaleString('tr-TR', { style: 'currency', currency: 'TRY' })}`;
                            }
                        }
                    }
                }
            }
        });

        // Çubuk Grafik
        const barCanvas = document.getElementById('barChart');
        const barData = parseData(barCanvas);

        new Chart(barCanvas, {
            type: 'bar',
            data: {
                labels: barData.labels,
                datasets: [{
                    label: 'Harcama',
                    data: barData.values,
                    backgroundColor: colors.slice(0, barData.values.length),
                    borderColor: colors.slice(0, barData.values.length).map(c => c.replace(')', ', 0.8)')), // hafif transparan sınır
                    borderWidth: 1
                }]
            },
            options: {
                responsive: true,
                scales: {
                    y: {
                        beginAtZero: true,
                        ticks: {
                            callback: val => val.toLocaleString('tr-TR', { style: 'currency', currency: 'TRY' })
                        }
                    }
                },
                plugins: {
                    legend: { display: false },
                    tooltip: {
                        callbacks: {
                            label: ctx => ctx.parsed.y.toLocaleString('tr-TR', { style: 'currency', currency: 'TRY' })
                        }
                    }
                }
            }
        });
    </script>
}
