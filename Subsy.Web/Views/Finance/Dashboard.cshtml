@model FinanceViewModel
@using System.Globalization
@using System.Text.Json
@using Subsy.Application.Finance.Dashboard

@{
    ViewData["Title"] = "Finansal Analiz";
    var tr = new CultureInfo("tr-TR");

    var catLabels = JsonSerializer.Serialize(Model.GroupedByCategory.Select(x => x.CategoryName));
    var catData = JsonSerializer.Serialize(Model.GroupedByCategory.Select(x => x.TotalCost));

    var categoryColors = new Dictionary<string, (string bg, string text)>
    {
        ["Eğlence"] = ("#fce4ec", "#c62828"),
        ["Müzik"] = ("#f3e5f5", "#7b1fa2"),
        ["Yazılım"] = ("#e3f2fd", "#1565c0"),
        ["Oyun"] = ("#e8f5e9", "#2e7d32"),
        ["Bulut"] = ("#e0f7fa", "#00838f"),
        ["Eğitim"] = ("#fff8e1", "#f57f17"),
        ["Haber"] = ("#efebe9", "#4e342e"),
        ["Sağlık"] = ("#e0f2f1", "#00695c"),
        ["Alışveriş"] = ("#fff3e0", "#e65100"),
        ["Diğer"] = ("#eceff1", "#546e7a")
    };

    (string bg, string text) GetCatColor(string name) =>
        categoryColors.GetValueOrDefault(name, ("#eceff1", "#546e7a"));

    string FormatOriginalPrice(decimal price, string currency)
    {
        return $"{price.ToString("N2", tr)} {currency}";
    }
}

@* ── Stat kartlar ────────────────────────────────────────── *@
<div class="stat-grid" style="margin-bottom:20px;">
    <div class="stat-card">
        <div class="stat-label">Aylık Maliyet</div>
        <div class="stat-value" style="font-size:20px; color:var(--accent); margin-top:4px;">@Model.TotalMonthlyCost.ToString("C0", tr)</div>
        <div class="stat-sub">Aylık eşdeğer toplamı</div>
    </div>
    <div class="stat-card">
        <div class="stat-label">Yıllık Tahmin</div>
        <div class="stat-value" style="font-size:20px; color:oklch(0.55 0.18 290); margin-top:4px;">@Model.TotalYearlyCost.ToString("C0", tr)</div>
        <div class="stat-sub">12 aylık projeksiyon</div>
    </div>
    <div class="stat-card">
        <div class="stat-label">Günlük Ortalama</div>
        <div class="stat-value" style="font-size:20px; color:var(--warning); margin-top:4px;">@Model.DailyAverage.ToString("C2", tr)</div>
        <div class="stat-sub">Her gün aboneliklere giden</div>
    </div>
    <div class="stat-card">
        <div class="stat-label">En Çok Maliyet</div>
        @if (Model.TopSpendingService is null)
        {
            <div class="stat-value" style="font-size:14px; color:var(--text-muted); margin-top:4px;">Veri yok</div>
        }
        else
        {
            <div class="stat-value" style="font-size:18px; color:var(--danger); margin-top:4px;">@Model.TopSpendingService.SubscriptionName</div>
            <div class="stat-sub">@Model.TopSpendingService.TotalCost.ToString("C0", tr) / ay</div>
        }
    </div>
</div>

@* ── Akıllı içgörüler ────────────────────────────────────── *@
@if (Model.Insights.Any())
{
    <div style="display:flex; flex-direction:column; gap:10px; margin-bottom:20px;">
        @foreach (var insight in Model.Insights)
        {
            var borderColor = insight.Type switch
            {
                "warning" => "var(--warning)",
                "info" => "var(--accent)",
                _ => "var(--border)"
            };
            <div class="card" style="padding:14px 18px; border-left:3px solid @borderColor; display:flex; align-items:center; gap:12px;">
                <span style="font-size:18px; flex-shrink:0;">@insight.Icon</span>
                <span style="font-size:13px; color:var(--text-primary);">@insight.Message</span>
            </div>
        }
    </div>
}

@* ── Ödeme takvimi + Kategori dağılımı ───────────────────── *@
<div style="display:grid; grid-template-columns:1fr 1fr; gap:20px; margin-bottom:20px;">

    <div class="card card-p">
        <div class="section-title" style="margin-bottom:16px;">Önümüzdeki 30 Gün</div>
        @if (!Model.PaymentCalendar.Any())
        {
            <div class="empty" style="padding:30px 0;">
                <div class="empty-text">30 gün içinde ödeme yok</div>
            </div>
        }
        else
        {
            <div style="display:flex; flex-direction:column; gap:16px;">
                @foreach (var week in Model.PaymentCalendar)
                {
                    <div>
                        <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:8px;">
                            <span style="font-size:12px; font-weight:600; color:var(--text-secondary);">@week.Label</span>
                            <span style="font-size:12px; font-weight:700; color:var(--text-primary);">@week.Total.ToString("C0", tr)</span>
                        </div>
                        @foreach (var item in week.Items)
                        {
                            <div style="display:flex; justify-content:space-between; align-items:center; padding:6px 0; border-bottom:1px solid var(--border);">
                                <div style="display:flex; align-items:center; gap:8px;">
                                    <span style="font-size:11px; color:var(--text-muted); min-width:50px;">@item.Date.ToString("d MMM", tr)</span>
                                    <span style="font-size:13px; font-weight:500;">@item.Name</span>
                                </div>
                                <span style="font-size:13px; font-weight:600;">@item.Amount.ToString("C0", tr)</span>
                            </div>
                        }
                    </div>
                }
            </div>
        }
    </div>

    <div class="card card-p">
        <div class="section-title" style="margin-bottom:16px;">Kategori Dağılımı</div>
        @if (!Model.GroupedByCategory.Any())
        {
            <div class="empty" style="padding:60px 0;">
                <div class="empty-text">Kategorize edilmiş abonelik yok</div>
            </div>
        }
        else
        {
            <div class="chart-wrap"><canvas id="categoryChart"></canvas></div>
        }
    </div>
</div>

@* ── Maliyet tablosu ─────────────────────────────────────── *@
<div class="card" style="margin-bottom:20px;">
    <div style="padding:16px 18px; border-bottom:1px solid var(--border);">
        <div class="section-title">Abonelik Maliyet Tablosu</div>
        <div style="font-size:12px; color:var(--text-secondary); margin-top:2px;">Aylık eşdeğer maliyete göre sıralı — tüm tutarlar @Model.Currency cinsinden</div>
    </div>
    @if (!Model.CostTable.Any())
    {
        <div class="empty" style="padding:40px;">
            <div class="empty-text">Aktif abonelik yok</div>
        </div>
    }
    else
    {
        <table class="table">
            <thead>
                <tr>
                    <th>Servis</th>
                    <th>Kategori</th>
                    <th>Periyot</th>
                    <th>Fiyat</th>
                    <th>Aylık Eşd.</th>
                    <th>Günlük</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var row in Model.CostTable)
                {
                    var cc = GetCatColor(row.CategoryName);
                    <tr>
                        <td style="font-weight:600; font-size:13px;">@row.Name</td>
                        <td>
                            <span style="display:inline-block; padding:2px 10px; border-radius:99px; font-size:11px; font-weight:600; background:@cc.bg; color:@cc.text;">@row.CategoryName</span>
                        </td>
                        <td style="font-size:12px; color:var(--text-secondary);">@row.Period</td>
                        <td style="font-size:13px;">@FormatOriginalPrice(row.OriginalPrice, row.OriginalCurrency)</td>
                        <td style="font-weight:600; font-size:13px; color:var(--accent);">@row.MonthlyCost.ToString("C0", tr)</td>
                        <td style="font-size:12px; color:var(--text-secondary);">@row.DailyCost.ToString("C2", tr)</td>
                    </tr>
                }
            </tbody>
        </table>
    }
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        const colors = ['#4f46e5','#0891b2','#059669','#d97706','#dc2626','#7c3aed','#0d9488','#db2777','#f59e0b','#3b82f6'];
        const fmtTRY = (v) => v.toLocaleString('tr-TR', { style: 'currency', currency: 'TRY' });

        const catLabels = @Html.Raw(catLabels);
        const catData = @Html.Raw(catData);

        if (catData.length > 0) {
            new Chart(document.getElementById('categoryChart'), {
                type: 'doughnut',
                data: {
                    labels: catLabels,
                    datasets: [{ data: catData, backgroundColor: colors.slice(0, catData.length), borderWidth: 2, borderColor: '#fff' }]
                },
                options: {
                    responsive: true, maintainAspectRatio: false,
                    cutout: '60%',
                    plugins: {
                        legend: { position: 'bottom', labels: { font: { family: 'DM Sans', size: 11 }, padding: 12, boxWidth: 10 } },
                        tooltip: { callbacks: { label: ctx => `${ctx.label}: ${fmtTRY(ctx.parsed || 0)}` } }
                    }
                }
            });
        }
    </script>
}
