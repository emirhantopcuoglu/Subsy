@{
    ViewData["Title"] = "Takvim";
}

<link href="https://cdn.jsdelivr.net/npm/fullcalendar@6.1.8/index.global.min.css" rel="stylesheet" />

<div style="display:flex; flex-direction:column; gap:16px;">
    <div class="card card-p">
        <div style="display:flex; flex-wrap:wrap; align-items:center; justify-content:space-between; gap:12px; margin-bottom:16px;">
            <div>
                <div class="section-title">Takvim</div>
                <div class="section-sub">Yenileme günlerini takip et, gecikmeleri yakala, hızlı aksiyon al.</div>
            </div>
            <div style="display:flex; flex-wrap:wrap; gap:8px; align-items:center;">
                <input id="calendarSearch" type="text" placeholder="Abonelik ara..." class="form-input" style="width:220px;" />
                <label style="display:inline-flex; align-items:center; gap:6px; font-size:13px; color:var(--text-secondary); cursor:pointer; user-select:none;">
                    <input id="toggleArchived" type="checkbox" style="accent-color:var(--accent); width:14px; height:14px;" />
                    Sonlandırılanları göster
                </label>
            </div>
        </div>

        <div style="display:flex; flex-wrap:wrap; gap:8px; font-size:12px;">
            <span style="display:inline-flex; align-items:center; gap:6px; background:var(--page-bg); border:1px solid var(--border); border-radius:20px; padding:3px 10px;">
                <span style="width:8px; height:8px; border-radius:50%; background:#EF4444; display:inline-block;"></span> Gecikmiş
            </span>
            <span style="display:inline-flex; align-items:center; gap:6px; background:var(--page-bg); border:1px solid var(--border); border-radius:20px; padding:3px 10px;">
                <span style="width:8px; height:8px; border-radius:50%; background:#F59E0B; display:inline-block;"></span> Bugün
            </span>
            <span style="display:inline-flex; align-items:center; gap:6px; background:var(--page-bg); border:1px solid var(--border); border-radius:20px; padding:3px 10px;">
                <span style="width:8px; height:8px; border-radius:50%; background:#EAB308; display:inline-block;"></span> 7 gün içinde
            </span>
            <span style="display:inline-flex; align-items:center; gap:6px; background:var(--page-bg); border:1px solid var(--border); border-radius:20px; padding:3px 10px;">
                <span style="width:8px; height:8px; border-radius:50%; background:#6366F1; display:inline-block;"></span> Yaklaşan
            </span>
            <span style="display:inline-flex; align-items:center; gap:6px; background:var(--page-bg); border:1px solid var(--border); border-radius:20px; padding:3px 10px;">
                <span style="width:8px; height:8px; border-radius:50%; background:#9CA3AF; display:inline-block;"></span> Sonlandırılmış
            </span>
        </div>
    </div>

    <div style="display:grid; grid-template-columns:1fr 300px; gap:16px;">
        <div class="card" style="padding:16px;">
            <div id="calendar"></div>
        </div>

        <div style="display:flex; flex-direction:column; gap:16px;">
            <div class="card card-p">
                <div class="section-title" style="margin-bottom:8px;">Seçili Gün</div>
                <div id="selectedDateLabel" style="font-size:12px; color:var(--text-secondary); margin-bottom:12px;">Bir güne tıkla</div>
                <div id="dayList">
                    <div style="font-size:13px; color:var(--text-muted);">Henüz seçim yok.</div>
                </div>
            </div>

            <div class="card card-p">
                <div class="section-title" style="margin-bottom:12px;">Yaklaşan 7 Gün</div>
                <div id="nextList">
                    <div style="font-size:13px; color:var(--text-muted);">Yükleniyor...</div>
                </div>
            </div>
        </div>
    </div>
</div>

<div id="eventModal" class="modal-overlay">
    <div class="modal">
        <div class="modal-header">
            <span id="mTitle" class="modal-title"></span>
            <button id="mClose" class="tb-btn" style="width:28px; height:28px; border:none;">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M6 18L18 6M6 6l12 12"/>
                </svg>
            </button>
        </div>
        <div class="modal-body">
            <p id="mMeta" style="color:var(--text-secondary); font-size:13px;"></p>
        </div>
        <div class="modal-footer">
            <a id="mEdit" class="btn btn-ghost btn-sm">Düzenle</a>
            <form id="mMarkPaidForm" method="post" style="display:inline;">
                <button type="submit" class="btn btn-success btn-sm">Ödendi / Yenile</button>
            </form>
            <form id="mArchiveToggleForm" method="post" style="display:inline;">
                <button id="mArchiveToggleBtn" type="submit" class="btn btn-ghost btn-sm">Sonlandır</button>
            </form>
        </div>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/fullcalendar@6.1.8/index.global.min.js"></script>
<script>
    document.addEventListener('DOMContentLoaded', () => {
        const calendarEl = document.getElementById('calendar');
        const searchEl = document.getElementById('calendarSearch');
        const includeArchivedEl = document.getElementById('toggleArchived');
        const selectedDateLabel = document.getElementById('selectedDateLabel');
        const dayList = document.getElementById('dayList');
        const nextList = document.getElementById('nextList');
        const modal = document.getElementById('eventModal');
        const mClose = document.getElementById('mClose');
        const mTitle = document.getElementById('mTitle');
        const mMeta = document.getElementById('mMeta');
        const mEdit = document.getElementById('mEdit');
        const mMarkPaidForm = document.getElementById('mMarkPaidForm');
        const mArchiveToggleForm = document.getElementById('mArchiveToggleForm');
        const mArchiveToggleBtn = document.getElementById('mArchiveToggleBtn');

        let allEventsCache = [];

        const formatDateTR = (dateStr) => {
            const d = new Date(dateStr + "T00:00:00");
            return d.toLocaleDateString("tr-TR", { year: "numeric", month: "long", day: "numeric" });
        };

        const matchesSearch = (ev) => {
            const q = (searchEl.value || "").trim().toLowerCase();
            if (!q) return true;
            return (ev.extendedProps?.name || ev.title || "").toLowerCase().includes(q);
        };

        const renderDayList = (dateStr) => {
            const items = allEventsCache.filter(e => e.start === dateStr).filter(matchesSearch);
            selectedDateLabel.textContent = formatDateTR(dateStr);
            if (items.length === 0) {
                dayList.innerHTML = `<div style="font-size:13px; color:var(--text-muted);">Bu gün için abonelik yok.</div>`;
                return;
            }
            dayList.innerHTML = items.map(e => `
                <button type="button" class="btn btn-ghost btn-sm" style="width:100%; justify-content:flex-start; margin-bottom:4px;" data-event-id="${e.id}">
                    <span style="width:8px; height:8px; border-radius:50%; background:${e.color || '#6366F1'}; flex-shrink:0;"></span>
                    <span style="font-size:12px; font-weight:600; flex:1; text-align:left;">${e.title}</span>
                </button>
            `).join("");
            dayList.querySelectorAll("button[data-event-id]").forEach(btn => {
                btn.addEventListener("click", () => {
                    const ev = allEventsCache.find(x => x.id === btn.dataset.eventId);
                    if (ev) openModal(ev);
                });
            });
        };

        const renderNext7 = () => {
            const today = new Date();
            const start = new Date(today.getFullYear(), today.getMonth(), today.getDate());
            const end = new Date(start); end.setDate(end.getDate() + 7);
            const items = allEventsCache.filter(matchesSearch)
                .map(e => ({ e, d: new Date(e.start + "T00:00:00") }))
                .filter(x => x.d >= start && x.d <= end)
                .sort((a, b) => a.d - b.d).slice(0, 12);
            if (items.length === 0) {
                nextList.innerHTML = `<div style="font-size:13px; color:var(--text-muted);">Yaklaşan 7 gün içinde ödeme yok.</div>`;
                return;
            }
            nextList.innerHTML = items.map(x => `
                <button type="button" class="btn btn-ghost btn-sm" style="width:100%; justify-content:flex-start; margin-bottom:4px;" data-event-id="${x.e.id}">
                    <span style="width:8px; height:8px; border-radius:50%; background:${x.e.color || '#6366F1'}; flex-shrink:0;"></span>
                    <div style="text-align:left; flex:1;">
                        <div style="font-size:12px; font-weight:600;">${x.e.title}</div>
                        <div style="font-size:11px; color:var(--text-muted);">${formatDateTR(x.e.start)}</div>
                    </div>
                </button>
            `).join("");
            nextList.querySelectorAll("button[data-event-id]").forEach(btn => {
                btn.addEventListener("click", () => {
                    const ev = allEventsCache.find(x => x.id === btn.dataset.eventId);
                    if (ev) openModal(ev);
                });
            });
        };

        const openModal = (ev) => {
            const p = ev.extendedProps || {};
            mTitle.textContent = p.name || ev.title;
            mMeta.textContent = `${formatDateTR(p.renewalDate || ev.start)} • ${p.price ?? ""} • ${p.status ?? ""}`;
            const subId = p.subscriptionId;
            mEdit.href = `/Subscription/Update/${subId}`;
            mMarkPaidForm.action = `/Subscription/MarkAsPaid/${subId}`;
            mMarkPaidForm.dataset.confirm = `${p.name || ev.title} aboneliğini ödendi olarak işaretlemek istiyor musunuz?`;
            mMarkPaidForm.dataset.confirmTitle = "Ödeme Onayı";
            mMarkPaidForm.dataset.confirmConfirmText = "Evet, işaretle";
            mMarkPaidForm.dataset.confirmVariant = "success";
            const paidBtn = mMarkPaidForm.querySelector("button[type='submit']");
            const payable = p.isPayable === true;
            paidBtn.disabled = !payable;
            if (!payable) { paidBtn.classList.add("btn-ghost"); paidBtn.style.opacity = "0.5"; }
            else { paidBtn.classList.remove("btn-ghost"); paidBtn.style.opacity = ""; }

            if (p.isArchived === true) {
                mArchiveToggleBtn.textContent = "Aktif Et";
                mArchiveToggleForm.action = `/Subscription/Unarchive/${subId}`;
                mArchiveToggleForm.dataset.confirm = `${p.name || ev.title} aboneliğini tekrar aktif etmek istiyor musunuz?`;
                mArchiveToggleForm.dataset.confirmTitle = "Aktifleştirme Onayı";
                mArchiveToggleForm.dataset.confirmConfirmText = "Evet, aktif et";
                mArchiveToggleForm.dataset.confirmVariant = "primary";
            } else {
                mArchiveToggleBtn.textContent = "Sonlandır";
                mArchiveToggleForm.action = `/Subscription/Archive/${subId}`;
                mArchiveToggleForm.dataset.confirm = `${p.name || ev.title} aboneliğini sonlandırmak istiyor musunuz?`;
                mArchiveToggleForm.dataset.confirmTitle = "Sonlandırma Onayı";
                mArchiveToggleForm.dataset.confirmConfirmText = "Evet, sonlandır";
                mArchiveToggleForm.dataset.confirmVariant = "danger";
            }
            modal.classList.add("open");
        };

        const closeModal = () => modal.classList.remove("open");
        mClose.addEventListener("click", closeModal);
        modal.addEventListener("click", (e) => { if (e.target === modal) closeModal(); });

        const calendar = new FullCalendar.Calendar(calendarEl, {
            initialView: 'dayGridMonth',
            height: 'auto',
            locale: 'tr',
            headerToolbar: { left: 'prev,next today', center: 'title', right: 'dayGridMonth,timeGridWeek,listWeek' },
            events: async (info, successCallback, failureCallback) => {
                try {
                    const url = new URL('/Subscription/CalendarEvents', window.location.origin);
                    url.searchParams.set('start', info.startStr);
                    url.searchParams.set('end', info.endStr);
                    url.searchParams.set('includeArchived', includeArchivedEl.checked ? 'true' : 'false');
                    const res = await fetch(url.toString(), { headers: { 'Accept': 'application/json' } });
                    if (!res.ok) throw new Error("Events fetch failed");
                    allEventsCache = await res.json() || [];
                    successCallback(allEventsCache);
                    renderNext7();
                } catch (err) { failureCallback(err); }
            },
            dateClick: (info) => renderDayList(info.dateStr),
            eventClick: (info) => openModal(info.event.toPlainObject())
        });

        calendar.render();
        searchEl.addEventListener("input", renderNext7);
        includeArchivedEl.addEventListener("change", () => calendar.refetchEvents());
    });
</script>
