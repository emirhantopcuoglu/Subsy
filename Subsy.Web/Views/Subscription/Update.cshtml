@model SubscriptionsViewModel
@using System.Globalization
@using Subsy.Domain.Enums
@using Subsy.Application.Common

@{
    ViewData["Title"] = "Abonelik Düzenle";
    var today = DateTime.Today;

    var categoryLabels = new Dictionary<SubscriptionCategory, string>
    {
        { SubscriptionCategory.Other, "Diğer" },
        { SubscriptionCategory.Entertainment, "Eğlence" },
        { SubscriptionCategory.Music, "Müzik" },
        { SubscriptionCategory.Software, "Yazılım" },
        { SubscriptionCategory.Gaming, "Oyun" },
        { SubscriptionCategory.Cloud, "Bulut" },
        { SubscriptionCategory.Education, "Eğitim" },
        { SubscriptionCategory.News, "Haber" },
        { SubscriptionCategory.Health, "Sağlık" },
        { SubscriptionCategory.Shopping, "Alışveriş" }
    };

    var grouped = ServiceRegistry.GetGrouped();
    var isKnownService = ServiceRegistry.TryGet(Model.Name) is not null;
}

<div style="display:flex; align-items:center; justify-content:space-between; margin-bottom:20px;">
    <div>
        <div class="section-title">Abonelik Düzenle</div>
        <div class="section-sub">@Model.Name</div>
    </div>
    <a asp-controller="Subscription" asp-action="Active" class="btn btn-ghost">İptal</a>
</div>

<div class="card card-p" style="max-width:540px;">
    <div asp-validation-summary="All"></div>

    <form asp-controller="Subscription" asp-action="Update" method="post">
        <input type="hidden" asp-for="Id" />

        <div class="form-group">
            <label class="form-label">Servis</label>
            <select id="serviceSelect" class="form-input form-select" onchange="onServiceChange()">
                <option value="">Servis seçiniz...</option>
                @foreach (var group in grouped)
                {
                    <optgroup label="@categoryLabels[group.Key]">
                        @foreach (var svc in group)
                        {
                            <option value="@svc.Name" data-category="@((int)svc.Category)"
                                    selected="@(svc.Name == Model.Name)">@svc.Name</option>
                        }
                    </optgroup>
                }
                <optgroup label="─────────">
                    <option value="__other__" selected="@(!isKnownService)">Diğer (Elle Giriş)</option>
                </optgroup>
            </select>
        </div>

        <div class="form-group" id="customNameGroup" style="display:@(isKnownService ? "none" : "");">
            <label class="form-label">Servis Adı</label>
            @if (isKnownService)
            {
                <input id="customNameInput" class="form-input" value="" placeholder="Abonelik adını yazın..." disabled />
            }
            else
            {
                <input id="customNameInput" class="form-input" value="@Model.Name" placeholder="Abonelik adını yazın..." name="Name" />
            }
            <span asp-validation-for="Name" class="field-validation-error"></span>
        </div>

        @if (isKnownService)
        {
            <input type="hidden" name="Name" id="hiddenName" value="@Model.Name" />
        }
        else
        {
            <input type="hidden" name="Name" id="hiddenName" value="" disabled />
        }

        <div class="form-grid-2">
            <div class="form-group">
                <label asp-for="Price" class="form-label">Tutar</label>
                <input asp-for="Price" class="form-input" type="number" step="0.01" />
                <span asp-validation-for="Price" class="field-validation-error"></span>
            </div>
            <div class="form-group">
                <label asp-for="Currency" class="form-label">Para Birimi</label>
                <select asp-for="Currency" class="form-input form-select">
                    <option value="TRY">TRY — Türk Lirası</option>
                    <option value="USD">USD — Dolar</option>
                    <option value="EUR">EUR — Euro</option>
                    <option value="GBP">GBP — Sterlin</option>
                </select>
                <span asp-validation-for="Currency" class="field-validation-error"></span>
            </div>
        </div>

        <div class="form-grid-2">
            <div class="form-group">
                <label asp-for="RenewalPeriodDays" class="form-label">Yenileme Sıklığı</label>
                <select asp-for="RenewalPeriodDays" class="form-input form-select">
                    <option value="">Seçiniz...</option>
                    <option value="7">Haftalık</option>
                    <option value="15">İki Haftada Bir</option>
                    <option value="30">Aylık</option>
                    <option value="90">3 Ayda Bir</option>
                    <option value="180">6 Ayda Bir</option>
                    <option value="365">Yıllık</option>
                </select>
                <span asp-validation-for="RenewalPeriodDays" class="field-validation-error"></span>
            </div>
            <div class="form-group" id="categoryGroup" style="display:@(!isKnownService ? "" : "none");">
                <label asp-for="Category" class="form-label">Kategori</label>
                <select asp-for="Category" class="form-input form-select" id="categorySelect">
                    @foreach (SubscriptionCategory cat in Enum.GetValues(typeof(SubscriptionCategory)))
                    {
                        <option value="@((int)cat)">@categoryLabels[cat]</option>
                    }
                </select>
            </div>
        </div>

        <div class="form-grid-2">
            <div class="form-group">
                <label class="form-label">Yenileme Ayı</label>
                <select id="month" name="SelectedMonth" class="form-input form-select" onchange="updateDays()">
                    @{
                        var selectedMonth = (int)(ViewBag.SelectedMonth ?? today.Month);
                        for (int i = 1; i <= 12; i++)
                        {
                            var monthName = CultureInfo.CurrentCulture.DateTimeFormat.GetMonthName(i);
                            <option value="@i" selected="@(i == selectedMonth)">@monthName</option>
                        }
                    }
                </select>
            </div>
            <div class="form-group">
                <label class="form-label">Yenileme Günü</label>
                <select id="day" name="SelectedDay" class="form-input form-select">
                    @{
                        var selectedDay = (int)(ViewBag.SelectedDay ?? today.Day);
                        for (int i = 1; i <= 31; i++)
                        {
                            <option value="@i" selected="@(i == selectedDay)">@i</option>
                        }
                    }
                </select>
            </div>
        </div>

        <div style="display:flex; gap:8px; margin-top:4px;">
            <button type="submit" class="btn btn-primary">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 13l4 4L19 7"/></svg>
                Kaydet
            </button>
            <a asp-controller="Subscription" asp-action="Active" class="btn btn-ghost">İptal</a>
        </div>
    </form>
</div>

@section Scripts {
    <script>
        function onServiceChange() {
            var sel = document.getElementById("serviceSelect");
            var val = sel.value;
            var customGroup = document.getElementById("customNameGroup");
            var hiddenName = document.getElementById("hiddenName");
            var customInput = document.getElementById("customNameInput");
            var categorySelect = document.getElementById("categorySelect");

            var categoryGroup = document.getElementById("categoryGroup");
            if (val === "__other__") {
                customGroup.style.display = "";
                hiddenName.disabled = true;
                customInput.name = "Name";
                customInput.disabled = false;
                customInput.focus();
                categoryGroup.style.display = "";
            } else if (val) {
                customGroup.style.display = "none";
                customInput.name = "";
                customInput.disabled = true;
                hiddenName.disabled = false;
                hiddenName.value = val;
                var opt = sel.options[sel.selectedIndex];
                var cat = opt.getAttribute("data-category");
                if (cat) categorySelect.value = cat;
                categoryGroup.style.display = "none";
            } else {
                customGroup.style.display = "none";
                customInput.name = "";
                customInput.disabled = true;
                hiddenName.disabled = false;
                hiddenName.value = "";
                categoryGroup.style.display = "none";
            }
        }

        function updateDays() {
            var month = parseInt(document.getElementById("month").value);
            var daySelect = document.getElementById("day");
            var year = new Date().getFullYear();
            var daysInMonth = new Date(year, month, 0).getDate();
            var currentSelected = parseInt(daySelect.value);
            daySelect.innerHTML = "";
            for (var d = 1; d <= daysInMonth; d++) {
                var option = document.createElement("option");
                option.value = d;
                option.text = d;
                if (d === currentSelected) option.selected = true;
                daySelect.appendChild(option);
            }
        }

        document.addEventListener("DOMContentLoaded", updateDays);
    </script>
}
