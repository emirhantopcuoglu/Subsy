@model SubscriptionsViewModel
@using System.Globalization

@{
    var today = DateTime.Today;
}

<!-- Sayfa Başlığı -->
<h2 class="text-2xl font-semibold mb-6 flex items-center gap-2">
    <!-- Pencil Icon -->
    <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6 text-amber-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M15.232 5.232l3.536 3.536M9 11l6 6m2-13a2.121 2.121 0 113 3L5 21l-4 1 1-4L16 5z" />
    </svg>
    Aboneliğini Güncelle
</h2>

<hr class="mb-8 border-gray-200">

<form asp-controller="Subscription" asp-action="Update" method="post" class="bg-white rounded-3xl shadow p-8 max-w-2xl space-y-6">
    <div asp-validation-summary="All" class="text-red-600 text-sm"></div>

    <input type="hidden" asp-for="Id" />

    <!-- Ad -->
    <div>
        <label asp-for="Name" class="block text-sm font-medium text-gray-700 mb-1"></label>
        <input asp-for="Name" class="block w-full px-4 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-indigo-500" />
        <span asp-validation-for="Name" class="text-red-600 text-sm"></span>
    </div>

    <!-- Fiyat -->
    <div>
        <label asp-for="Price" class="block text-sm font-medium text-gray-700 mb-1"></label>
        <input asp-for="Price" class="block w-full px-4 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-indigo-500" />
        <span asp-validation-for="Price" class="text-red-600 text-sm"></span>
    </div>

    <!-- Para Birimi -->
    <div>
        <label asp-for="Currency" class="block text-sm font-medium text-gray-700 mb-1">Para Birimi</label>
        <select asp-for="Currency" class="block w-full px-4 py-2 border border-gray-300 rounded-lg bg-white focus:outline-none focus:ring-2 focus:ring-indigo-500">
            <option value="TRY">TRY - Türk Lirası</option>
            <option value="USD">USD - Amerikan Doları</option>
            <option value="EUR">EUR - Euro</option>
            <option value="GBP">GBP - İngiliz Sterlini</option>
        </select>
        <span asp-validation-for="Currency" class="text-red-600 text-sm"></span>
    </div>

    <!-- Yenileme Sıklığı -->
    <div>
        <label asp-for="RenewalPeriodDays" class="block text-sm font-medium text-gray-700 mb-1">Yenileme Sıklığı</label>
        <select asp-for="RenewalPeriodDays" class="block w-full px-4 py-2 border border-gray-300 rounded-lg bg-white focus:outline-none focus:ring-2 focus:ring-indigo-500">
            <option value="">Seçiniz...</option>
            <option value="7">Haftalık</option>
            <option value="15">İki Haftada Bir</option>
            <option value="30">Aylık</option>
            <option value="90">3 Ayda Bir</option>
            <option value="180">6 Ayda Bir</option>
            <option value="365">Yıllık</option>
        </select>
        <span asp-validation-for="RenewalPeriodDays" class="text-red-600 text-sm"></span>
    </div>

    <!-- Ay & Gün Seçimi -->
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
        <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">Yenileme Ayı</label>
            <select id="month" name="SelectedMonth" class="block w-full px-4 py-2 border border-gray-300 rounded-lg bg-white focus:outline-none focus:ring-2 focus:ring-indigo-500" onchange="updateDays()">
                @{
                    var selectedMonth = (int)(ViewBag.SelectedMonth ?? today.Month);
                    for (int i = 1; i <= 12; i++)
                    {
                        var monthName = CultureInfo.CurrentCulture.DateTimeFormat.GetMonthName(i);
                        <option value="@i" selected="@(i == selectedMonth)">@monthName</option>
                    }
                }
            </select>
        </div>
        <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">Yenileme Günü</label>
            <select id="day" name="SelectedDay" class="block w-full px-4 py-2 border border-gray-300 rounded-lg bg-white focus:outline-none focus:ring-2 focus:ring-indigo-500">
                @{
                    var selectedDay = (int)(ViewBag.SelectedDay ?? today.Day);
                    for (int i = 1; i <= 31; i++)
                    {
                        <option value="@i" selected="@(i == selectedDay)">@i</option>
                    }
                }
            </select>
        </div>
    </div>

    <!-- Kaydet Butonu -->
    <button type="submit" class="inline-flex items-center gap-2 px-6 py-3 rounded-lg text-white bg-indigo-600 hover:bg-indigo-700 focus:outline-none focus:ring-2 focus:ring-indigo-500">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
        </svg>
        Kaydet
    </button>
</form>

@section Scripts {
    <script>
        function updateDays() {
            const month = parseInt(document.getElementById("month").value);
            const daySelect = document.getElementById("day");

            const year = new Date().getFullYear();
            const daysInMonth = new Date(year, month, 0).getDate();

            const currentSelected = parseInt(daySelect.value);

            daySelect.innerHTML = "";

            for (let d = 1; d <= daysInMonth; d++) {
                const option = document.createElement("option");
                option.value = d;
                option.text = d;
                if (d === currentSelected) {
                    option.selected = true;
                }
                daySelect.appendChild(option);
            }
        }

        document.addEventListener("DOMContentLoaded", updateDays);
    </script>
}