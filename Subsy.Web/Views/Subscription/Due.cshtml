@model List<SubscriptionsViewModel>
@using System.Globalization
@using Subsy.Domain.Enums
@using Subsy.Application.Common

@{
    ViewData["Title"] = "Ödeme Günü";
    var tr = new CultureInfo("tr-TR");
    string[] avatarColors = { "#4f46e5","#0891b2","#059669","#d97706","#dc2626","#7c3aed","#0d9488","#db2777" };
    string AvatarColor(string name) => avatarColors[char.ToUpper(name[0]) % avatarColors.Length];

    var categoryLabels = new Dictionary<SubscriptionCategory, string>
    {
        { SubscriptionCategory.Other, "Diğer" },
        { SubscriptionCategory.Entertainment, "Eğlence" },
        { SubscriptionCategory.Music, "Müzik" },
        { SubscriptionCategory.Software, "Yazılım" },
        { SubscriptionCategory.Gaming, "Oyun" },
        { SubscriptionCategory.Cloud, "Bulut" },
        { SubscriptionCategory.Education, "Eğitim" },
        { SubscriptionCategory.News, "Haber" },
        { SubscriptionCategory.Health, "Sağlık" },
        { SubscriptionCategory.Shopping, "Alışveriş" }
    };

    var categoryChipClass = new Dictionary<SubscriptionCategory, string>
    {
        { SubscriptionCategory.Other, "chip-other" },
        { SubscriptionCategory.Entertainment, "chip-entertainment" },
        { SubscriptionCategory.Music, "chip-music" },
        { SubscriptionCategory.Software, "chip-software" },
        { SubscriptionCategory.Gaming, "chip-gaming" },
        { SubscriptionCategory.Cloud, "chip-cloud" },
        { SubscriptionCategory.Education, "chip-education" },
        { SubscriptionCategory.News, "chip-news" },
        { SubscriptionCategory.Health, "chip-health" },
        { SubscriptionCategory.Shopping, "chip-shopping" }
    };
}

<div style="display:flex; align-items:center; justify-content:space-between; margin-bottom:20px;">
    <div>
        <div class="section-title">Ödeme Günü Gelen Abonelikler</div>
        <div class="section-sub">@Model.Count abonelik bekliyor</div>
    </div>
</div>

@if (!Model.Any())
{
    <div class="card">
        <div class="empty">
            <div class="empty-icon">
                <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M5 13l4 4L19 7"/>
                </svg>
            </div>
            <div class="empty-text">Ödeme günü gelmiş aboneliğiniz bulunmamaktadır.</div>
        </div>
    </div>
}
else
{
    <div class="sub-grid">
        @foreach (var sub in Model)
        {
            var remaining = (sub.RenewalDate - DateTime.Today).Days;
            var expiredDays = Math.Abs(remaining);
            var color = AvatarColor(sub.Name);
            var periodLabel = sub.RenewalPeriodDays switch { 7 => "Haftalık", 30 => "Aylık", 365 => "Yıllık", _ => $"{sub.RenewalPeriodDays}g" };
            var faviconUrl = ServiceRegistry.GetFaviconUrl(sub.Name);

            <div class="sub-card overdue">
                <div style="display:flex; align-items:flex-start; gap:10px; justify-content:space-between;">
                    <div style="display:flex; align-items:center; gap:10px;">
                        @if (faviconUrl is not null)
                        {
                            <img src="@faviconUrl" alt="@sub.Name" class="sub-favicon" onerror="this.style.display='none';this.nextElementSibling.style.display='flex';" />
                            <div class="sub-avatar" style="background:@color; display:none;">@sub.Name[0].ToString().ToUpper()</div>
                        }
                        else
                        {
                            <div class="sub-avatar" style="background:@color;">@sub.Name[0].ToString().ToUpper()</div>
                        }
                        <div>
                            <div class="sub-name">@sub.Name</div>
                            <div class="sub-meta">@sub.Currency · @periodLabel</div>
                        </div>
                    </div>
                    <div style="display:flex; flex-direction:column; align-items:flex-end; gap:4px;">
                        @if (expiredDays == 0)
                        {
                            <span class="chip chip-red">Bugün</span>
                        }
                        else
                        {
                            <span class="chip chip-red">@expiredDays g gecikmiş</span>
                        }
                        <span class="chip chip-cat @categoryChipClass[sub.Category]">@categoryLabels[sub.Category]</span>
                    </div>
                </div>

                <div>
                    <div class="sub-price">@sub.Price.ToString("C2", tr)</div>
                    <div class="sub-meta" style="margin-top:2px;">Yenileme: @sub.RenewalDate.ToString("d MMM yyyy", tr)</div>
                </div>

                <div>
                    <div class="progress-track">
                        <div class="progress-fill" style="width:100%; background:var(--danger);"></div>
                    </div>
                </div>

                <div style="display:flex; gap:6px; flex-wrap:wrap; margin-top:auto;">
                    <form method="post" asp-controller="Subscription" asp-action="MarkAsPaid" asp-route-id="@sub.Id"
                          data-confirm="@sub.Name aboneliğini yenilemek istiyor musunuz?"
                          data-confirm-title="Yenileme Onayı"
                          data-confirm-confirm-text="Evet, yenile"
                          data-confirm-variant="success">
                        <button type="submit" class="btn btn-success btn-sm">
                            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 13l4 4L19 7"/></svg>
                            Yenile
                        </button>
                    </form>
                    <a asp-action="Update" asp-route-id="@sub.Id" class="btn btn-ghost btn-sm">
                        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
                        Düzenle
                    </a>
                </div>
            </div>
        }
    </div>
}
