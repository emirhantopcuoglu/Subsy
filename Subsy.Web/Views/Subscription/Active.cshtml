@model List<SubscriptionsViewModel>
@using System.Globalization
@using Subsy.Domain.Enums
@using Subsy.Application.Common

@{
    ViewData["Title"] = "Aktif Abonelikler";
    var tr = new CultureInfo("tr-TR");
    string[] avatarColors = { "#4f46e5","#0891b2","#059669","#d97706","#dc2626","#7c3aed","#0d9488","#db2777" };
    string AvatarColor(string name) => avatarColors[char.ToUpper(name[0]) % avatarColors.Length];

    var categoryLabels = new Dictionary<SubscriptionCategory, string>
    {
        { SubscriptionCategory.Other, "Diğer" },
        { SubscriptionCategory.Entertainment, "Eğlence" },
        { SubscriptionCategory.Music, "Müzik" },
        { SubscriptionCategory.Software, "Yazılım" },
        { SubscriptionCategory.Gaming, "Oyun" },
        { SubscriptionCategory.Cloud, "Bulut" },
        { SubscriptionCategory.Education, "Eğitim" },
        { SubscriptionCategory.News, "Haber" },
        { SubscriptionCategory.Health, "Sağlık" },
        { SubscriptionCategory.Shopping, "Alışveriş" }
    };

    var categoryChipClass = new Dictionary<SubscriptionCategory, string>
    {
        { SubscriptionCategory.Other, "chip-other" },
        { SubscriptionCategory.Entertainment, "chip-entertainment" },
        { SubscriptionCategory.Music, "chip-music" },
        { SubscriptionCategory.Software, "chip-software" },
        { SubscriptionCategory.Gaming, "chip-gaming" },
        { SubscriptionCategory.Cloud, "chip-cloud" },
        { SubscriptionCategory.Education, "chip-education" },
        { SubscriptionCategory.News, "chip-news" },
        { SubscriptionCategory.Health, "chip-health" },
        { SubscriptionCategory.Shopping, "chip-shopping" }
    };

    var currencies = Model.Select(m => m.Currency).Distinct().OrderBy(c => c).ToList();
}

<div style="display:flex; align-items:center; justify-content:space-between; margin-bottom:20px;">
    <div>
        <div class="section-title">Aktif Abonelikler</div>
        <div class="section-sub"><span id="visible-count">@Model.Count</span> abonelik</div>
    </div>
    <a asp-controller="Subscription" asp-action="Create" class="btn btn-primary">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 5v14M5 12h14"/></svg>
        Yeni Ekle
    </a>
</div>

@if (!Model.Any())
{
    <div class="card">
        <div class="empty">
            <div class="empty-icon">
                <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M8 6h13M8 12h13M8 18h13M3 6h.01M3 12h.01M3 18h.01"/>
                </svg>
            </div>
            <div class="empty-text">Aktif aboneliğiniz bulunmamaktadır.</div>
        </div>
    </div>
}
else
{
    <div class="toolbar">
        <select id="sortBy" class="toolbar-select" onchange="applyFilters()">
            <option value="name-asc">Ada Göre (A-Z)</option>
            <option value="name-desc">Ada Göre (Z-A)</option>
            <option value="price-asc">Fiyat (Düşükten Yükseğe)</option>
            <option value="price-desc">Fiyat (Yüksekten Düşüğe)</option>
            <option value="date-asc">Yenileme (Yakın)</option>
            <option value="date-desc">Yenileme (Uzak)</option>
        </select>

        @if (currencies.Count > 1)
        {
            <select id="filterCurrency" class="toolbar-select" onchange="applyFilters()">
                <option value="">Tüm Para Birimleri</option>
                @foreach (var c in currencies)
                {
                    <option value="@c">@c</option>
                }
            </select>
        }

        <select id="filterCategory" class="toolbar-select" onchange="applyFilters()">
            <option value="">Tüm Kategoriler</option>
            @foreach (SubscriptionCategory cat in Enum.GetValues(typeof(SubscriptionCategory)))
            {
                if (Model.Any(m => m.Category == cat))
                {
                    <option value="@((int)cat)">@categoryLabels[cat]</option>
                }
            }
        </select>
    </div>

    <div class="sub-grid" id="sub-grid">
        @foreach (var sub in Model)
        {
            var period = sub.RenewalPeriodDays <= 0 ? 30 : sub.RenewalPeriodDays;
            var remaining = (sub.RenewalDate - DateTime.Today).Days;
            var used = period - remaining;
            var percent = Math.Clamp((used * 100) / period, 0, 100);
            var expired = remaining <= 0;
            var periodLabel = period switch { 7 => "Haftalık", 15 => "İki Haftada Bir", 30 => "Aylık", 90 => "3 Ayda Bir", 180 => "6 Ayda Bir", 365 => "Yıllık", _ => $"{period}g" };
            var color = AvatarColor(sub.Name);
            var faviconUrl = ServiceRegistry.GetFaviconUrl(sub.Name);

            <div class="sub-card @(expired ? "overdue" : "")"
                 data-name="@sub.Name"
                 data-price="@sub.Price"
                 data-date="@sub.RenewalDate.ToString("yyyy-MM-dd")"
                 data-currency="@sub.Currency"
                 data-category="@((int)sub.Category)">
                <div style="display:flex; align-items:flex-start; gap:10px; justify-content:space-between;">
                    <div style="display:flex; align-items:center; gap:10px;">
                        @if (faviconUrl is not null)
                        {
                            <img src="@faviconUrl" alt="@sub.Name" class="sub-favicon" onerror="this.style.display='none';this.nextElementSibling.style.display='flex';" />
                            <div class="sub-avatar" style="background:@color; display:none;">@sub.Name[0].ToString().ToUpper()</div>
                        }
                        else
                        {
                            <div class="sub-avatar" style="background:@color;">@sub.Name[0].ToString().ToUpper()</div>
                        }
                        <div>
                            <div class="sub-name">@sub.Name</div>
                            <div class="sub-meta">@sub.Currency · @periodLabel</div>
                        </div>
                    </div>
                    <div style="display:flex; flex-direction:column; align-items:flex-end; gap:4px;">
                        @if (expired)
                        {
                            <span class="chip chip-red">Gecikmiş</span>
                        }
                        else if (remaining <= 3)
                        {
                            <span class="chip chip-blue">@remaining g</span>
                        }
                        else
                        {
                            <span class="chip chip-green">@remaining g</span>
                        }
                        <span class="chip chip-cat @categoryChipClass[sub.Category]">@categoryLabels[sub.Category]</span>
                    </div>
                </div>

                <div>
                    <div class="sub-price">@sub.Price.ToString("C2", tr)</div>
                    <div class="sub-meta" style="margin-top:2px;">Yenileme: @sub.RenewalDate.ToString("d MMM yyyy", tr)</div>
                </div>

                <div>
                    <div class="progress-track">
                        <div class="progress-fill" style="width:@percent%; background:@(expired ? "var(--danger)" : percent > 75 ? "var(--warning)" : "var(--success)");"></div>
                    </div>
                    <div style="display:flex; justify-content:space-between; margin-top:4px;">
                        <span style="font-size:11px; color:var(--text-muted);">Dönem başlangıcı</span>
                        <span style="font-size:11px; color:var(--text-muted);">@percent%</span>
                    </div>
                </div>

                <div style="display:flex; gap:6px; flex-wrap:wrap; margin-top:auto;">
                    @if (expired)
                    {
                        <form method="post" asp-action="MarkAsPaid" asp-route-id="@sub.Id"
                              data-confirm="@sub.Name aboneliğini ödendi olarak işaretlemek istiyor musunuz?"
                              data-confirm-title="Ödeme Onayı"
                              data-confirm-confirm-text="Evet, işaretle"
                              data-confirm-variant="success">
                            <button type="submit" class="btn btn-success btn-sm">
                                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 13l4 4L19 7"/></svg>
                                Ödendi
                            </button>
                        </form>
                    }
                    <a asp-action="Update" asp-route-id="@sub.Id" class="btn btn-ghost btn-sm">
                        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
                        Düzenle
                    </a>
                    <form method="post" asp-controller="Subscription" asp-action="Archive" asp-route-id="@sub.Id"
                          data-confirm="@sub.Name aboneliğini sonlandırmak istiyor musunuz?"
                          data-confirm-title="Sonlandırma Onayı"
                          data-confirm-confirm-text="Evet, sonlandır"
                          data-confirm-variant="danger">
                        <button type="submit" class="btn btn-danger btn-sm">
                            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 7H4a2 2 0 0 0-2 2v1a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2V9a2 2 0 0 0-2-2z"/><path d="M10 13v4M14 13v4M8 7V5a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"/></svg>
                            Sonlandır
                        </button>
                    </form>
                </div>
            </div>
        }
    </div>
}

@section Scripts {
    <script>
        function applyFilters() {
            var sortBy = document.getElementById("sortBy").value;
            var currencyEl = document.getElementById("filterCurrency");
            var currency = currencyEl ? currencyEl.value : "";
            var categoryEl = document.getElementById("filterCategory");
            var category = categoryEl ? categoryEl.value : "";
            var grid = document.getElementById("sub-grid");
            if (!grid) return;

            var cards = Array.from(grid.querySelectorAll(".sub-card"));

            cards.forEach(function (card) {
                var show = true;
                if (currency && card.dataset.currency !== currency) show = false;
                if (category && card.dataset.category !== category) show = false;
                card.style.display = show ? "" : "none";
            });

            var visible = cards.filter(function (c) { return c.style.display !== "none"; });

            visible.sort(function (a, b) {
                switch (sortBy) {
                    case "name-asc": return a.dataset.name.localeCompare(b.dataset.name, "tr");
                    case "name-desc": return b.dataset.name.localeCompare(a.dataset.name, "tr");
                    case "price-asc": return parseFloat(a.dataset.price) - parseFloat(b.dataset.price);
                    case "price-desc": return parseFloat(b.dataset.price) - parseFloat(a.dataset.price);
                    case "date-asc": return a.dataset.date.localeCompare(b.dataset.date);
                    case "date-desc": return b.dataset.date.localeCompare(a.dataset.date);
                    default: return 0;
                }
            });

            visible.forEach(function (card) { grid.appendChild(card); });

            var countEl = document.getElementById("visible-count");
            if (countEl) countEl.textContent = visible.length;
        }
    </script>
}
