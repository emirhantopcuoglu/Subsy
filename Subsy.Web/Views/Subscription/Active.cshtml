@model List<SubscriptionsViewModel>
@using System.Globalization

@{
    ViewData["Title"] = "Aktif Abonelikler";
}

<!-- Başlık + Yeni Abonelik Butonu -->
<div class="flex items-center justify-between mb-6">
    <h2 class="text-2xl font-semibold">Aktif Aboneliklerim</h2>

    <a asp-controller="Subscription" asp-action="Create" class="inline-flex items-center gap-2 px-5 py-2 rounded-lg text-white bg-gradient-to-r from-indigo-600 to-purple-700 hover:from-indigo-700 hover:to-purple-800 text-sm shadow">
        <!-- Plus Icon -->
        <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4" />
        </svg>
        Yeni Abonelik
    </a>
</div>

@if (!Model.Any())
{
    <div class="flex items-start gap-3 bg-gray-100 border-l-4 border-gray-400 text-gray-600 rounded-xl p-4 shadow">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6 shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M13 16h-1v-4h-1m1-4h.01M12 2a10 10 0 100 20 10 10 0 000-20z" />
        </svg>
        <p>Aktif aboneliğiniz bulunmamaktadır.</p>
    </div>
}
else
{
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
        @foreach (var sub in Model)
        {
            var period = sub.RenewalPeriodDays <= 0 ? 30 : sub.RenewalPeriodDays;
            var remaining = (sub.RenewalDate - DateTime.Today).Days;
            var used = period - remaining;
            var percent = Math.Clamp((used * 100) / period, 0, 100);
            var expired = remaining <= 0;

            var borderClass = expired ? "border-red-500" : "border-transparent";
            var progressColor = expired ? "bg-red-500" : "bg-emerald-500";
            var renewalText = expired ? "Süresi doldu, ödeme bekleniyor" : $"{remaining} gün";
            <div class="bg-white border-2 @borderClass rounded-2xl shadow p-6 flex flex-col h-full">
                <!-- Başlık -->
                <h3 class="text-lg font-semibold mb-2">@sub.Name</h3>

                <!-- Abonelik Bilgileri -->
                <p class="text-sm text-gray-600 leading-relaxed mb-4">
                    <span class="font-medium text-gray-800">@sub.Price </span><br />
                    Yenileme Tarihi: @sub.RenewalDate.ToString("d MMMM yyyy", CultureInfo.CurrentCulture)<br />
                    Kalan: @renewalText
                </p>

                <!-- Progress Bar -->
                <div class="w-full h-3 rounded-full bg-gray-200 mb-6 overflow-hidden">
                    <div class="@progressColor h-full rounded-full transition-all duration-500" style="width:@percent%;"></div>
                </div>

                <!-- Aksiyon Butonları -->
                <div class="mt-auto flex flex-wrap gap-2">
                    @if (expired)
                    {
                        <form method="post"
                              asp-action="MarkAsPaid"
                              asp-route-id="@sub.Id"
                              data-confirm="@sub.Name aboneliğini ödendi olarak işaretlemek istiyor musunuz?"
                              data-confirm-title="Ödeme Onayı"
                              data-confirm-confirm-text="Evet, işaretle"
                              data-confirm-variant="success">
                            <button class="inline-flex items-center gap-1 px-4 py-2 rounded-lg text-white bg-emerald-600 hover:bg-emerald-700 text-sm">
                                <!-- Check Icon -->
                                <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                                    <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
                                </svg>
                                Ödendi
                            </button>
                        </form>
                    }

                    <a asp-action="Update" asp-route-id="@sub.Id" class="inline-flex items-center gap-1 px-4 py-2 rounded-lg text-white bg-amber-500 hover:bg-amber-600 text-sm">
                        <!-- Pencil Icon -->
                        <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M15.232 5.232l3.536 3.536M9 11l6 6m2-13a2.121 2.121 0 113 3L5 21l-4 1 1-4L16 5z" />
                        </svg>
                        Düzenle
                    </a>

                    <form method="post"
                          asp-controller="Subscription"
                          asp-action="Archive"
                          asp-route-id="@sub.Id"
                          data-confirm="@sub.Name aboneliğini sonlandırmak istiyor musunuz?"
                          data-confirm-title="Sonlandırma Onayı"
                          data-confirm-confirm-text="Evet, sonlandır"
                          data-confirm-variant="danger">
                        <button type="submit" class="inline-flex items-center gap-1 px-4 py-2 rounded-lg text-white bg-red-600 hover:bg-red-700 text-sm">
                            <!-- Trash Icon -->
                            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5-4h4m-4 0a1 1 0 00-1 1v1h6V4a 1 1 0 00-1-1m-4 0h4" />
                            </svg>
                            Sonlandır
                        </button>
                    </form>
                </div>
            </div>
        }
    </div>
}
