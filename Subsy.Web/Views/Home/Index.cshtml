@{
    ViewData["Title"] = "Subsy - Aboneliklerini Takip Et";
}

<div style="min-height:100vh; display:flex; flex-direction:column; align-items:center; justify-content:center; padding:40px 20px; background:var(--page-bg);">
    <div style="max-width:720px; text-align:center;">
        <div style="font-size:22px; font-weight:700; margin-bottom:32px; color:var(--text-primary);">
            sub<span style="color:var(--accent);">sy</span>
        </div>

        <h1 style="font-size:48px; font-weight:700; line-height:1.1; letter-spacing:-1px; color:var(--text-primary); margin-bottom:20px;">
            Aboneliklerinizi <span style="color:var(--accent);">Kontrol Altına Alın</span>
        </h1>

        <p style="font-size:17px; color:var(--text-secondary); line-height:1.6; margin-bottom:36px; max-width:560px; margin-left:auto; margin-right:auto;">
            Netflix, Spotify, Amazon Prime... Ne kadar harcıyorsunuz biliyor musunuz?
            Subsy ile tüm aboneliklerinizi tek yerden yönetin.
        </p>

        <div style="display:flex; gap:10px; justify-content:center; flex-wrap:wrap;">
            <a asp-controller="Account" asp-action="Register" class="btn btn-primary" style="padding:12px 24px; font-size:14px;">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M12 5v14M5 12h14"/>
                </svg>
                Hemen Başla
            </a>
            <a asp-controller="Account" asp-action="Login" class="btn btn-ghost" style="padding:12px 24px; font-size:14px;">
                Giriş Yap
            </a>
        </div>
    </div>
</div>
