@model Subsy.Web.Models.ErrorViewModel
@{
    ViewData["Title"] = "Hata";
}

<div class="login-wrap">
    <div class="login-card">
        <h1 style="font-size:20px; font-weight:700; color:var(--text-primary); margin-bottom:8px;">Bir şeyler ters gitti</h1>
        <p style="font-size:13px; color:var(--text-secondary); margin-bottom:16px;">
            Şu an işleminizi tamamlayamadık. Lütfen sayfayı yenileyin veya daha sonra tekrar deneyin.
        </p>

        @if (!string.IsNullOrWhiteSpace(Model?.RequestId))
        {
            <p style="font-size:12px; color:var(--text-muted); margin-bottom:20px;">
                Hata Kodu: <span style="font-family:monospace;">@Model.RequestId</span>
            </p>
        }

        <div style="display:flex; gap:8px;">
            <a asp-controller="Home" asp-action="Index" class="btn btn-primary">Ana sayfaya dön</a>
            <button onclick="location.reload()" class="btn btn-ghost">Yenile</button>
        </div>
    </div>
</div>
