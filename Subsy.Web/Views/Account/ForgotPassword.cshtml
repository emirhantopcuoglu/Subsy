@model ForgotPasswordViewModel
@{
    ViewData["Title"] = "Şifremi Unuttum";
}

<div class="login-wrap">
    <div class="login-card">
        <div class="login-logo">sub<span>sy</span></div>
        <div style="font-size:13px; color:var(--text-secondary); margin-bottom:24px;">Parola sıfırlama bağlantısı göndereceğiz</div>

        <div asp-validation-summary="All"></div>

        <form asp-controller="Account" asp-action="ForgotPassword" method="post">
            <div class="form-group">
                <label asp-for="Email" class="form-label">E-posta</label>
                <input asp-for="Email" type="email" class="form-input" placeholder="ornek@email.com" autofocus />
                <span asp-validation-for="Email" class="field-validation-error"></span>
            </div>

            <button type="submit" class="btn btn-primary" style="width:100%; justify-content:center; padding:10px;">
                Sıfırlama Bağlantısı Gönder
            </button>
        </form>

        <div style="margin-top:16px; text-align:center; font-size:13px; color:var(--text-secondary);">
            <a asp-controller="Account" asp-action="Login" style="color:var(--accent); font-weight:500;">← Giriş sayfasına dön</a>
        </div>
    </div>
</div>
