@model LoginWith2faViewModel
@{
    ViewData["Title"] = "İki Faktörlü Doğrulama";
}

<div class="login-wrap">
    <div class="login-card">
        <div class="login-logo">sub<span>sy</span></div>
        <div style="font-size:13px; color:var(--text-secondary); margin-bottom:24px;">Kimlik doğrulayıcı uygulamanızdaki kodu girin</div>

        <div asp-validation-summary="All"></div>

        <form asp-controller="Account" asp-action="LoginWith2fa" method="post">
            <input asp-for="RememberMe" type="hidden" />
            <div class="form-group">
                <label asp-for="TwoFactorCode" class="form-label">Doğrulama Kodu</label>
                <input asp-for="TwoFactorCode" class="form-input" placeholder="000000"
                       autocomplete="one-time-code" inputmode="numeric" maxlength="7" autofocus />
                <span asp-validation-for="TwoFactorCode" class="field-validation-error"></span>
            </div>

            <button type="submit" class="btn btn-primary" style="width:100%; justify-content:center; padding:10px;">
                Doğrula ve Giriş Yap
            </button>
        </form>

        <div style="margin-top:16px; text-align:center; font-size:13px; color:var(--text-secondary);">
            <a asp-controller="Account" asp-action="Login" style="color:var(--accent);">← Geri dön</a>
        </div>
    </div>
</div>
