@{
    ViewData["Title"] = "E-postanızı Doğrulayın";
    Layout = null;
}
<!DOCTYPE html>
<html lang="tr" data-theme="light">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Subsy</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <script>(function(){try{var d=localStorage.getItem('subsy-dark')==='true';document.documentElement.setAttribute('data-theme',d?'dark':'light');}catch(e){}})()</script>
</head>
<body>
<div class="login-wrap">
    <div class="login-card" style="text-align:center;">
        <div class="login-logo">sub<span>sy</span></div>
        <div style="font-size:40px; margin: 16px 0;">✉️</div>
        <h2 style="font-size:18px; font-weight:600; margin-bottom:8px;">E-postanızı Doğrulayın</h2>
        <p style="color:var(--text-secondary); font-size:14px; line-height:1.6; margin-bottom:24px;">
            <strong>@ViewBag.Email</strong> adresine bir doğrulama bağlantısı gönderildi.
            Lütfen gelen kutunuzu kontrol edin ve bağlantıya tıklayın.
        </p>
        <div style="font-size:13px; color:var(--text-muted);">
            Mail gelmediyse spam klasörünü kontrol edin veya
            <a asp-controller="Account" asp-action="ResendConfirmation" style="color:var(--accent);">tekrar gönderin</a>.
        </div>
    </div>
</div>
</body>
</html>
