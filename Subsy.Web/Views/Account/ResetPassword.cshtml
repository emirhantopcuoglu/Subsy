@model ResetPasswordViewModel
@{
    ViewData["Title"] = "Parola Sıfırla";
}

<div class="login-wrap">
    <div class="login-card">
        <div class="login-logo">sub<span>sy</span></div>
        <div style="font-size:13px; color:var(--text-secondary); margin-bottom:24px;">Yeni parolanızı belirleyin</div>

        <div asp-validation-summary="All"></div>

        <form asp-controller="Account" asp-action="ResetPassword" method="post">
            <input asp-for="UserId" type="hidden" />
            <input asp-for="Token" type="hidden" />

            <div class="form-group">
                <label asp-for="NewPassword" class="form-label">Yeni Parola</label>
                <input asp-for="NewPassword" type="password" class="form-input" placeholder="••••••••" />
                <span asp-validation-for="NewPassword" class="field-validation-error"></span>
            </div>

            <div class="form-group">
                <label asp-for="ConfirmPassword" class="form-label">Yeni Parola (Tekrar)</label>
                <input asp-for="ConfirmPassword" type="password" class="form-input" placeholder="••••••••" />
                <span asp-validation-for="ConfirmPassword" class="field-validation-error"></span>
            </div>

            <button type="submit" class="btn btn-primary" style="width:100%; justify-content:center; padding:10px;">
                Parolayı Sıfırla
            </button>
        </form>
    </div>
</div>
