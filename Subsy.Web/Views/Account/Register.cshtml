@model RegisterViewModel

<div class="login-wrap">
    <div class="login-card">
        <div class="login-logo">sub<span>sy</span></div>
        <div style="font-size:13px; color:var(--text-secondary); margin-bottom:24px;">Yeni hesap oluşturun</div>

        <div asp-validation-summary="All" class="validation-summary-errors"></div>

        <form asp-controller="Account" asp-action="Register" method="post">
            <div class="form-group">
                <label asp-for="UserName" class="form-label">Kullanıcı Adı</label>
                <input asp-for="UserName" class="form-input" placeholder="kullanici_adi" />
                <span asp-validation-for="UserName" class="field-validation-error"></span>
            </div>

            <div class="form-group">
                <label asp-for="Email" class="form-label">E-posta</label>
                <input asp-for="Email" type="email" class="form-input" placeholder="ornek@email.com" />
                <span asp-validation-for="Email" class="field-validation-error"></span>
            </div>

            <div class="form-group">
                <label asp-for="Password" class="form-label">Parola</label>
                <input asp-for="Password" type="password" class="form-input" placeholder="••••••••" />
                <span asp-validation-for="Password" class="field-validation-error"></span>
            </div>

            <div class="form-group">
                <label asp-for="ConfirmPassword" class="form-label">Parola (Tekrar)</label>
                <input asp-for="ConfirmPassword" type="password" class="form-input" placeholder="••••••••" />
                <span asp-validation-for="ConfirmPassword" class="field-validation-error"></span>
            </div>

            <button type="submit" class="btn btn-primary" style="width:100%; justify-content:center; padding:10px; margin-top:4px;">Hesap Oluştur</button>
        </form>

        <div style="margin-top:16px; text-align:center; font-size:13px; color:var(--text-secondary);">
            Zaten hesabınız var mı?
            <a asp-controller="Account" asp-action="Login" style="color:var(--accent); font-weight:500;">Giriş Yap</a>
        </div>
    </div>
</div>
