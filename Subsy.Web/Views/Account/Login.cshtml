@model LoginViewModel

@await Component.InvokeAsync("FlashMessage")

<!-- Tam ekran ortalanmış giriş kartı -->
<section class="min-h-screen flex items-center justify-center bg-gray-50 py-12 px-4 sm:px-6 lg:px-8">
    <div class="w-full max-w-md space-y-8 bg-white shadow-xl rounded-3xl p-8">
        <!-- Başlık -->
        <div class="text-center">
            <h2 class="text-3xl font-extrabold text-indigo-600 tracking-tight">Giriş Yap</h2>
        </div>

        <form asp-controller="Account" asp-action="Login" method="post" class="mt-8 space-y-6">
            <div asp-validation-summary="All" class="text-red-600 text-sm"></div>

            <!-- E-posta -->
            <div>
                <label asp-for="Email" class="block text-sm font-medium text-gray-700 mb-1">E-Posta</label>
                <input asp-for="Email" class="block w-full px-4 py-2 border border-gray-300 rounded-lg placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-indigo-500" placeholder="E-posta adresinizi giriniz" />
                <span asp-validation-for="Email" class="text-red-600 text-sm"></span>
            </div>

            <!-- Şifre -->
            <div>
                <label asp-for="Password" class="block text-sm font-medium text-gray-700 mb-1">Şifre</label>
                <input asp-for="Password" type="password" class="block w-full px-4 py-2 border border-gray-300 rounded-lg placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-indigo-500" placeholder="Şifrenizi giriniz" />
                <span asp-validation-for="Password" class="text-red-600 text-sm"></span>
            </div>

            <!-- Beni Hatırla -->
            <div class="flex items-center">
                <input asp-for="RememberMe" type="checkbox" class="h-4 w-4 text-indigo-600 focus:ring-indigo-500 border-gray-300 rounded" />
                <label asp-for="RememberMe" class="ml-2 block text-sm text-gray-700 select-none">Beni Hatırla</label>
            </div>

            <!-- Gönder Butonu -->
            <div>
                <button type="submit" class="w-full inline-flex items-center justify-center gap-2 px-6 py-3 rounded-lg text-white bg-gradient-to-r from-indigo-600 to-purple-700 hover:from-indigo-700 hover:to-purple-800 focus:outline-none focus:ring-2 focus:ring-indigo-500 font-semibold shadow-md">
                    <!-- Login Icon -->
                    <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M15 3h4a2 2 0 012 2v14a2 2 0 01-2 2h-4M10 17l5-5m0 0l-5-5m5 5H3" />
                    </svg>
                    Giriş Yap
                </button>
            </div>
        </form>
    </div>
</section>