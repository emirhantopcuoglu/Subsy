<!DOCTYPE html>
<html lang="tr" class="h-full">
<head>
    <meta charset="utf-8" />
    <title>@ViewData["Title"] - Subsy</title>
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" />

    <script src="https://cdn.tailwindcss.com"></script>
</head>

<body class="h-full bg-gray-100">
    @if (User?.Identity?.IsAuthenticated == true)
    {
        @await Html.PartialAsync("_Sidebar")

        <main class="min-h-screen ml-64 p-6">
            @await Component.InvokeAsync("FlashMessage")
            @RenderBody()
        </main>
    }
    else
    {
        @await Html.PartialAsync("_TopNavbar")
        <div class="container mt-4">
            @await Component.InvokeAsync("FlashMessage")
            @RenderBody()
        </div>
    }

    <div id="confirmBoxOverlay" class="fixed inset-0 hidden items-center justify-center bg-slate-900/40 p-4 z-[80]">
        <div class="w-full max-w-sm rounded-2xl border border-slate-200 bg-white p-5 shadow-2xl">
            <h3 id="confirmBoxTitle" class="text-base font-semibold text-slate-900">İşlemi Onayla</h3>
            <p id="confirmBoxMessage" class="mt-2 text-sm text-slate-600"></p>

            <div class="mt-5 flex justify-end gap-2">
                <button id="confirmBoxCancel" type="button"
                        class="inline-flex items-center rounded-lg border border-slate-300 px-3 py-2 text-sm font-medium text-slate-700 hover:bg-slate-100">
                    Vazgeç
                </button>
                <button id="confirmBoxApprove" type="button"
                        class="inline-flex items-center rounded-lg px-3 py-2 text-sm font-medium text-white bg-indigo-600 hover:bg-indigo-700">
                    Evet, devam et
                </button>
            </div>
        </div>
    </div>

    <script>
        document.addEventListener("DOMContentLoaded", function () {
            const overlay = document.getElementById("confirmBoxOverlay");
            const titleEl = document.getElementById("confirmBoxTitle");
            const messageEl = document.getElementById("confirmBoxMessage");
            const cancelBtn = document.getElementById("confirmBoxCancel");
            const approveBtn = document.getElementById("confirmBoxApprove");

            if (!overlay || !titleEl || !messageEl || !cancelBtn || !approveBtn) {
                return;
            }

            let pendingForm = null;

            const variantClasses = [
                "bg-indigo-600", "hover:bg-indigo-700",
                "bg-emerald-600", "hover:bg-emerald-700",
                "bg-red-600", "hover:bg-red-700"
            ];

            const applyVariant = (variant) => {
                approveBtn.classList.remove(...variantClasses);
                if (variant === "danger") {
                    approveBtn.classList.add("bg-red-600", "hover:bg-red-700");
                    return;
                }

                if (variant === "success") {
                    approveBtn.classList.add("bg-emerald-600", "hover:bg-emerald-700");
                    return;
                }

                approveBtn.classList.add("bg-indigo-600", "hover:bg-indigo-700");
            };

            const closeDialog = () => {
                overlay.classList.add("hidden");
                overlay.classList.remove("flex");
                pendingForm = null;
            };

            const openDialog = (form) => {
                pendingForm = form;
                titleEl.textContent = form.dataset.confirmTitle || "İşlemi Onayla";
                messageEl.textContent = form.dataset.confirm || "";
                approveBtn.textContent = form.dataset.confirmConfirmText || "Evet, devam et";
                cancelBtn.textContent = form.dataset.confirmCancelText || "Vazgeç";
                applyVariant(form.dataset.confirmVariant || "primary");

                overlay.classList.remove("hidden");
                overlay.classList.add("flex");
                approveBtn.focus();
            };

            document.addEventListener("submit", function (event) {
                const form = event.target;
                if (!(form instanceof HTMLFormElement)) {
                    return;
                }

                const message = form.dataset.confirm;
                if (!message) {
                    return;
                }

                event.preventDefault();
                event.stopPropagation();
                openDialog(form);
            }, true);

            approveBtn.addEventListener("click", function () {
                if (!pendingForm) {
                    return;
                }

                const formToSubmit = pendingForm;
                closeDialog();
                formToSubmit.submit();
            });

            cancelBtn.addEventListener("click", closeDialog);
            overlay.addEventListener("click", function (event) {
                if (event.target === overlay) {
                    closeDialog();
                }
            });

            document.addEventListener("keydown", function (event) {
                if (event.key === "Escape" && !overlay.classList.contains("hidden")) {
                    closeDialog();
                }
            });
        });
    </script>

    @RenderSection("Scripts", required: false)
</body>
</html>
