@{
    var title = ViewData["Title"]?.ToString() ?? "Subsy";
    var controller = (ViewContext.RouteData.Values["controller"]?.ToString() ?? "").ToLowerInvariant();
    var action = (ViewContext.RouteData.Values["action"]?.ToString() ?? "").ToLowerInvariant();
    var hideNewButton = controller == "subscription" && (action == "create" || action == "update");
}

<header class="topbar">
    <span class="tb-title">@title</span>
    <div class="tb-spacer"></div>
    <button class="tb-btn" id="darkToggle" title="Temayı Değiştir">
        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
        </svg>
    </button>
    @if (!hideNewButton)
    {
        <a asp-controller="Subscription" asp-action="Create" class="btn btn-primary btn-sm">
            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M12 5v14M5 12h14"/>
            </svg>
            Yeni Abonelik
        </a>
    }
</header>
