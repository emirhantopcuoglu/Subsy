<!DOCTYPE html>
<html lang="tr" class="h-full">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Abonelik Paneli</title>
    <!-- Tailwind CSS CDN -->
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="h-full bg-gray-100">
    <!-- Kenar Çubuğu -->
    <aside class="fixed inset-y-0 left-0 w-64 flex flex-col bg-gradient-to-b from-indigo-600 to-purple-700 text-white shadow-2xl">
        <!-- Kullanıcı Bilgisi -->
        <div class="flex flex-col items-center py-8">
            <img src="/images/user-placeholder.png" alt="Kullanıcı" class="w-20 h-20 rounded-full ring-4 ring-white/40" />
            <p class="mt-3 text-lg font-semibold">@User.Identity.Name</p>
        </div>

        <!-- Navigasyon -->
        <nav class="flex-1 px-4 space-y-1">
            <a class="flex items-center gap-3 px-4 py-2 rounded-lg hover:bg-white/10 transition" asp-controller="Subscription" asp-action="Index">
                <!-- Home Icon -->
                <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2h-4a2 2 0 0 1-2-2V12H9v8a2 2 0 0 1-2 2H3a2 2 0 0 1-2-2V9z" />
                </svg>
                <span>Anasayfa</span>
            </a>

            <a class="flex items-center gap-3 px-4 py-2 rounded-lg hover:bg-white/10 transition" asp-controller="Subscription" asp-action="Active">
                <!-- Folder Icon -->
                <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M3 7h5l2 3h11v11H3z" />
                </svg>
                <span>Aktif Abonelikler</span>
            </a>

            <a class="flex items-center gap-3 px-4 py-2 rounded-lg hover:bg-white/10 transition" asp-controller="Subscription" asp-action="Due">
                <!-- Alarm Calendar Icon -->
                <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <rect x="3" y="4" width="18" height="18" rx="2" ry="2" />
                    <line x1="16" y1="2" x2="16" y2="6" />
                    <line x1="8" y1="2" x2="8" y2="6" />
                    <line x1="3" y1="10" x2="21" y2="10" />
                </svg>
                <span>Ödeme Günü Gelenler</span>
            </a>

            <!-- Yeni Takvim Sayfası -->
            <a class="flex items-center gap-3 px-4 py-2 rounded-lg hover:bg-white/10 transition" asp-controller="Subscription" asp-action="Calendar">
                <!-- Calendar Icon -->
                <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M8 7V3m8 4V3m-9 8h10m-9 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                </svg>
                <span>Takvim</span>
            </a>

            <a class="flex items-center gap-3 px-4 py-2 rounded-lg hover:bg-white/10 transition" asp-controller="Subscription" asp-action="Archived">
                <!-- Archive Icon -->
                <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <rect x="3" y="3" width="18" height="4" rx="2" ry="2" />
                    <path d="M5 7v13a2 2 0 0 0 2 2h10a2 2 0 0 0 2-2V7" />
                    <line x1="10" y1="11" x2="14" y2="11" />
                </svg>
                <span>Sonlandırılanlar</span>
            </a>

            <a class="flex items-center gap-3 px-4 py-2 rounded-lg hover:bg-white/10 transition" asp-controller="Finance" asp-action="Dashboard">
                <!-- Chart Icon -->
                <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <line x1="3" y1="12" x2="21" y2="12" />
                    <line x1="12" y1="3" x2="12" y2="21" />
                    <path d="M4 17l4-4 3 3 6-6 3 3" />
                </svg>
                <span>Finansal Analiz</span>
            </a>

            <span class="flex items-center gap-3 px-4 py-2 rounded-lg opacity-40 cursor-not-allowed select-none">
                <!-- User Icon -->
                <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M20 21v-2a4 4 0 0 0-3-3.87" />
                    <path d="M4 21v-2a4 4 0 0 1 3-3.87" />
                    <circle cx="12" cy="7" r="4" />
                </svg>
                <span>Profil (yakında)</span>
            </span>
        </nav>

        <!-- Çıkış Yap butonu -->
        <div class="px-4 py-6">
            <form asp-controller="Account" asp-action="Logout" method="post">
                <button class="flex items-center gap-3 w-full px-4 py-2 rounded-lg hover:bg-white/10 transition">
                    <!-- Logout Icon -->
                    <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4" />
                        <polyline points="16 17 21 12 16 7" />
                        <line x1="21" y1="12" x2="9" y2="12" />
                    </svg>
                    <span>Çıkış Yap</span>
                </button>
            </form>
        </div>
    </aside>
</body>
</html>
