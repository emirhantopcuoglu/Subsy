@using System.Security.Claims
@inject Subsy.Application.Common.Interfaces.IUserProfileService UserProfileService

@{
    var currentController = (ViewContext.RouteData.Values["controller"]?.ToString() ?? "").ToLowerInvariant();
    var currentAction = (ViewContext.RouteData.Values["action"]?.ToString() ?? "").ToLowerInvariant();

    var userId = User.FindFirstValue(ClaimTypes.NameIdentifier);
    var profile = string.IsNullOrWhiteSpace(userId)
        ? null
        : await UserProfileService.GetByUserIdAsync(userId);

    var hasPhoto = !string.IsNullOrWhiteSpace(profile?.ProfilePhotoPath);
    var profilePhotoPath = hasPhoto ? profile!.ProfilePhotoPath : null;
    var userName = User.Identity?.Name ?? "Kullanıcı";
    var userInitial = userName.Length > 0 ? userName[0].ToString().ToUpper() : "K";

    string NavClass(string controller, string action = "")
    {
        var c = controller.ToLowerInvariant();
        var a = action?.ToLowerInvariant() ?? "";
        var isActive = currentController == c && (string.IsNullOrWhiteSpace(a) || currentAction == a);
        return isActive ? "s-item active" : "s-item";
    }
}

<aside class="sidebar">
    <div class="s-logo">
        <div class="s-logo-text">sub<span>sy</span></div>
    </div>

    <div class="s-user">
        <div class="s-avatar">
            @if (hasPhoto)
            {
                <img src="@profilePhotoPath" alt="@userName" />
            }
            else
            {
                @userInitial
            }
        </div>
        <div class="s-user-info">
            <div class="name">@userName</div>
            <div class="role">Kişisel Plan</div>
        </div>
    </div>

    <nav class="s-nav">
        <a class="@NavClass("Dashboard", "Index")" asp-controller="Dashboard" asp-action="Index">
            <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2h-4v-6H9v6H5a2 2 0 0 1-2-2V9z"/>
            </svg>
            Dashboard
        </a>

        <a class="@NavClass("Subscription", "Active")" asp-controller="Subscription" asp-action="Active">
            <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M8 6h13M8 12h13M8 18h13M3 6h.01M3 12h.01M3 18h.01"/>
            </svg>
            Aktif Abonelikler
        </a>

        <a class="@NavClass("Subscription", "Due")" asp-controller="Subscription" asp-action="Due">
            <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M12 22a10 10 0 1 0 0-20 10 10 0 0 0 0 20"/><path d="M12 6v6l4 2"/>
            </svg>
            Ödeme Günü
        </a>

        <a class="@NavClass("Subscription", "Calendar")" asp-controller="Subscription" asp-action="Calendar">
            <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M8 2v4M16 2v4M3 10h18M5 4h14a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2z"/>
            </svg>
            Takvim
        </a>

        <a class="@NavClass("Subscription", "Archived")" asp-controller="Subscription" asp-action="Archived">
            <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M20 7H4a2 2 0 0 0-2 2v1a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2V9a2 2 0 0 0-2-2z"/><path d="M10 13v4M14 13v4M8 7V5a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"/>
            </svg>
            Sonlandırılanlar
        </a>

        <div class="s-label">Analiz</div>

        <a class="@NavClass("Finance", "Dashboard")" asp-controller="Finance" asp-action="Dashboard">
            <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M3 3v18h18"/><path d="M7 16l4-4 4 4 4-5"/>
            </svg>
            Finansal Analiz
        </a>

        <div class="s-label">Hesap</div>

        <a class="@NavClass("Profile", "Index")" asp-controller="Profile" asp-action="Index">
            <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><path d="M12 3a4 4 0 1 0 0 8 4 4 0 0 0 0-8z"/>
            </svg>
            Profil
        </a>
    </nav>

    <div class="s-footer">
        <form asp-controller="Account" asp-action="Logout" method="post">
            <button type="submit" class="s-item" style="color: var(--danger); opacity: 0.85;">
                <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/><polyline points="16 17 21 12 16 7"/><line x1="21" y1="12" x2="9" y2="12"/>
                </svg>
                Çıkış Yap
            </button>
        </form>
    </div>
</aside>
