@model List<(string Key, string Message, string Type, int Duration)>
@* Tailwind tabanlı flash mesaj bileşeni *@

@functions {
    string GetColor(string type)
    {
        return type switch
        {
            "success" => "emerald",
            "danger" or "error" => "red",
            "warning" => "amber",
            "info" => "sky",
            _ => "gray"
        };
    }

    string GetIconPath(string type) => type switch
    {
        "success" => "M5 13l4 4L19 7",           // Check
        "danger" or "error" => "M6 18L18 6M6 6l12 12", // X
        "warning" => "M13 16h-1v-4h-1m1-4h.01",  // !
        "info" => "M13 16h-1v-4h-1m1-4h.01",     // i
        _ => string.Empty
    };
}

@{
    var flashInstanceId = $"flash-{Guid.NewGuid():N}";
}

@for (var i = 0; i < Model.Count; i++)
{
    var msg = Model[i];
    var color = GetColor(msg.Type);
    var icon = GetIconPath(msg.Type);
    var bg = $"bg-{color}-100";
    var border = $"border-{color}-500";
    var text = $"text-{color}-800";
    var elementId = $"{flashInstanceId}-{msg.Key}-{i}";

    <div id="@elementId" class="@bg @border border-l-4 rounded-xl p-4 mb-4 flex items-start gap-3 shadow">
        @if (!string.IsNullOrEmpty(icon))
        {
            <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 @text mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="@icon" />
            </svg>
        }
        <span class="block @text">@msg.Message</span>
    </div>

    <script>
        setTimeout(() => {
            const el = document.getElementById("@elementId");
            if (el) {
                el.classList.add('opacity-0', 'transition', 'duration-500');
                setTimeout(() => el.remove(), 500);
            }
        }, @msg.Duration);
    </script>
}
