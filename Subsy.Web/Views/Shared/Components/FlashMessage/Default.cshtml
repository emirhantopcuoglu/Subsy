@model List<(string Key, string Message, string Type, int Duration)>

@functions {
    string AlertClass(string type) => type switch
    {
        "success" => "alert-success",
        "danger" or "error" => "alert-danger",
        "warning" => "alert-warning",
        _ => "alert-info"
    };

    string IconPath(string type) => type switch
    {
        "success" => "M5 13l4 4L19 7",
        "danger" or "error" => "M6 18L18 6M6 6l12 12",
        "warning" => "M12 9v4m0 4h.01M10.29 3.86L1.82 18a2 2 0 001.71 3h16.94a2 2 0 001.71-3L13.71 3.86a2 2 0 00-3.42 0z",
        _ => "M13 16h-1v-4h-1m1-4h.01M12 2a10 10 0 100 20 10 10 0 000-20z"
    };
}

@{
    var instanceId = $"flash-{Guid.NewGuid():N}";
}

@for (var i = 0; i < Model.Count; i++)
{
    var msg = Model[i];
    var elementId = $"{instanceId}-{i}";

    <div id="@elementId" class="alert @AlertClass(msg.Type)" style="transition: opacity 0.5s ease;">
        <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="flex-shrink:0; margin-top:1px;">
            <path d="@IconPath(msg.Type)" />
        </svg>
        <span>@msg.Message</span>
    </div>

    <script>
        setTimeout(function () {
            var el = document.getElementById("@elementId");
            if (el) {
                el.style.opacity = "0";
                setTimeout(function () { el.remove(); }, 500);
            }
        }, @msg.Duration);
    </script>
}
