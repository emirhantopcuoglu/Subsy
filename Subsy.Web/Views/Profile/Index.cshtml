@model ProfileViewModel

@{
    ViewData["Title"] = "Profil";
}

<div class="profile-grid">
    <div class="card card-p" style="display:flex; flex-direction:column; align-items:center; gap:12px; text-align:center;">
        <img src="@Model.ProfilePhotoPath" alt="Profil fotoğrafı"
             style="width:80px; height:80px; border-radius:50%; object-fit:cover; border:3px solid var(--accent-light);" />

        <div>
            <div style="font-weight:700; font-size:15px; color:var(--text-primary);">@Model.UserName</div>
            <div style="font-size:12px; color:var(--text-secondary);">@Model.Email</div>
        </div>

        <div style="font-size:11px; color:var(--text-muted);">
            Kayıt: @Model.RegisteredAt.ToLocalTime().ToString("dd.MM.yyyy")
        </div>

        <div style="width:100%; border-top:1px solid var(--border); padding-top:12px; margin-top:4px;">
            <div class="form-label" style="margin-bottom:8px; text-transform:uppercase; letter-spacing:0.05em; font-size:10px;">Fotoğraf Güncelle</div>
            <form asp-controller="Profile" asp-action="UploadPhoto" method="post" enctype="multipart/form-data"
                  style="display:flex; flex-direction:column; gap:8px;">
                <label style="display:block; padding:8px; border:1px dashed var(--border); border-radius:7px; cursor:pointer; font-size:12px; color:var(--text-secondary); text-align:center;">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="vertical-align:middle; margin-right:4px;">
                        <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="17 8 12 3 7 8"/><line x1="12" y1="3" x2="12" y2="15"/>
                    </svg>
                    Dosya Seç
                    <input type="file" name="photo" accept="image/png,image/jpeg,image/webp" style="display:none;" />
                </label>
                <button type="submit" class="btn btn-primary" style="justify-content:center;">Fotoğrafı Güncelle</button>
            </form>
        </div>
    </div>

    <div style="display:flex; flex-direction:column; gap:16px;">
        <div class="card card-p">
            <div class="section-title" style="margin-bottom:16px;">Profil Bilgileri</div>

            <form asp-controller="Profile" asp-action="UpdateInfo" method="post">
                <div asp-validation-summary="All" class="validation-summary-errors"></div>

                <div class="form-group">
                    <label asp-for="UserName" class="form-label">Kullanıcı Adı</label>
                    <input asp-for="UserName" class="form-input" />
                    <span asp-validation-for="UserName" class="field-validation-error"></span>
                </div>

                <div class="form-group">
                    <label asp-for="Email" class="form-label">E-posta</label>
                    <input asp-for="Email" type="email" class="form-input" />
                    <span asp-validation-for="Email" class="field-validation-error"></span>
                </div>

                <button type="submit" class="btn btn-primary">Bilgileri Kaydet</button>
            </form>
        </div>

        <div class="card card-p">
            <div class="section-title" style="margin-bottom:16px;">Parola Değiştir</div>

            <form asp-controller="Profile" asp-action="ChangePassword" method="post">
                <div class="form-group">
                    <label asp-for="CurrentPassword" class="form-label">Mevcut Parola</label>
                    <input asp-for="CurrentPassword" type="password" class="form-input" placeholder="••••••••" />
                    <span asp-validation-for="CurrentPassword" class="field-validation-error"></span>
                </div>

                <div class="form-group">
                    <label asp-for="NewPassword" class="form-label">Yeni Parola</label>
                    <input asp-for="NewPassword" type="password" class="form-input" placeholder="••••••••" />
                    <span asp-validation-for="NewPassword" class="field-validation-error"></span>
                </div>

                <div class="form-group">
                    <label asp-for="ConfirmNewPassword" class="form-label">Yeni Parola (Tekrar)</label>
                    <input asp-for="ConfirmNewPassword" type="password" class="form-input" placeholder="••••••••" />
                    <span asp-validation-for="ConfirmNewPassword" class="field-validation-error"></span>
                </div>

                <button type="submit" class="btn btn-ghost" style="border-color:var(--text-primary); color:var(--text-primary);">
                    Parolayı Değiştir
                </button>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
