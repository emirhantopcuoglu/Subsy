@model IReadOnlyList<Subsy.Application.Admin.Queries.GetAllUsers.AdminUserDto>
@using System.Security.Claims
@{
    ViewData["Title"] = "Kullanıcılar";
    var currentUserId = User.FindFirstValue(ClaimTypes.NameIdentifier);
}

<div style="display:flex; align-items:center; gap:12px; margin-bottom:20px; flex-wrap:wrap;">
    <input type="text" id="userSearch" class="form-input" placeholder="Kullanıcı adı veya e-posta ara..."
           style="max-width:320px;" />
    <span style="font-size:13px; color:var(--text-muted);">@Model.Count kullanıcı</span>
</div>

<div class="card" style="overflow:hidden;">
    <table class="table" style="width:100%;" id="userTable">
        <thead>
            <tr>
                <th>Kullanıcı Adı</th>
                <th>E-posta</th>
                <th>Abonelik</th>
                <th>Durum</th>
                <th style="text-align:right;">İşlemler</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var user in Model)
            {
                var isSelf = user.Id == currentUserId;
                <tr data-search="@user.UserName.ToLower() @user.Email.ToLower()"
                    style="@(user.IsBlocked ? "opacity:0.6;" : "")">
                    <td style="font-weight:500;">
                        @user.UserName
                        @if (isSelf)
                        {
                            <span class="chip chip-gray" style="font-size:10px; margin-left:4px;">Sen</span>
                        }
                    </td>
                    <td style="color:var(--text-secondary); font-size:13px;">@user.Email</td>
                    <td style="color:var(--text-secondary); font-size:13px;">@user.SubscriptionCount</td>
                    <td>
                        <div style="display:flex; gap:4px; flex-wrap:wrap;">
                            @if (user.IsAdmin)
                            {
                                <span class="chip chip-success">Admin</span>
                            }
                            else
                            {
                                <span class="chip chip-gray">Kullanıcı</span>
                            }
                            @if (user.IsBlocked)
                            {
                                <span class="chip" style="background:var(--danger-light); color:var(--danger);">Engelli</span>
                            }
                        </div>
                    </td>
                    <td style="text-align:right; white-space:nowrap;">
                        <div style="display:flex; gap:4px; justify-content:flex-end; flex-wrap:wrap; align-items:center;">

                            @* Detay *@
                            <a asp-area="Admin" asp-controller="Users" asp-action="Details" asp-route-userId="@user.Id"
                               class="btn btn-ghost" style="font-size:12px;">Detay</a>

                            @if (!isSelf)
                            {
                                @* Rol yönetimi *@
                                @if (user.IsAdmin)
                                {
                                    <form asp-area="Admin" asp-controller="Users" asp-action="RevokeAdmin" method="post"
                                          data-confirm="@user.UserName adlı kullanıcının admin rolü kaldırılacak."
                                          data-confirm-title="Admin Rolünü Kaldır"
                                          data-confirm-variant="danger">
                                        <input type="hidden" name="userId" value="@user.Id" />
                                        <button type="submit" class="btn btn-ghost" style="font-size:12px; color:var(--danger);">
                                            Rolü Kaldır
                                        </button>
                                    </form>
                                }
                                else
                                {
                                    <form asp-area="Admin" asp-controller="Users" asp-action="AssignAdmin" method="post"
                                          data-confirm="@user.UserName adlı kullanıcıya admin rolü atanacak."
                                          data-confirm-title="Admin Rolü Ata">
                                        <input type="hidden" name="userId" value="@user.Id" />
                                        <button type="submit" class="btn btn-ghost" style="font-size:12px;">
                                            Admin Yap
                                        </button>
                                    </form>
                                }

                                @* Engelleme *@
                                @if (user.IsBlocked)
                                {
                                    <form asp-area="Admin" asp-controller="Users" asp-action="Unblock" method="post">
                                        <input type="hidden" name="userId" value="@user.Id" />
                                        <button type="submit" class="btn btn-ghost" style="font-size:12px;">
                                            Engeli Kaldır
                                        </button>
                                    </form>
                                }
                                else
                                {
                                    <form asp-area="Admin" asp-controller="Users" asp-action="Block" method="post"
                                          data-confirm="@user.UserName adlı kullanıcı engellenecek. Giriş yapamayacak."
                                          data-confirm-title="Kullanıcıyı Engelle"
                                          data-confirm-variant="danger">
                                        <input type="hidden" name="userId" value="@user.Id" />
                                        <button type="submit" class="btn btn-ghost" style="font-size:12px; color:var(--warning);">
                                            Engelle
                                        </button>
                                    </form>
                                }

                                @* Oturumu Kapat *@
                                <form asp-area="Admin" asp-controller="Users" asp-action="ForceLogout" method="post"
                                      data-confirm="@user.UserName adlı kullanıcının aktif oturumu sonlandırılacak."
                                      data-confirm-title="Oturumu Sonlandır"
                                      data-confirm-variant="danger">
                                    <input type="hidden" name="userId" value="@user.Id" />
                                    <button type="submit" class="btn btn-ghost" style="font-size:12px; color:var(--warning);">
                                        Oturumu Kapat
                                    </button>
                                </form>

                                @* Parola Sıfırla *@
                                <form asp-area="Admin" asp-controller="Users" asp-action="SendPasswordReset" method="post"
                                      data-confirm="@user.UserName adlı kullanıcıya parola sıfırlama e-postası gönderilecek."
                                      data-confirm-title="Parola Sıfırla">
                                    <input type="hidden" name="userId" value="@user.Id" />
                                    <button type="submit" class="btn btn-ghost" style="font-size:12px;">
                                        Parola Sıfırla
                                    </button>
                                </form>

                                @* Silme *@
                                <form asp-area="Admin" asp-controller="Users" asp-action="Delete" method="post"
                                      data-confirm="@user.UserName adlı kullanıcı ve tüm verileri (abonelikler, profil) kalıcı olarak silinecek. Bu işlem geri alınamaz!"
                                      data-confirm-title="Kullanıcıyı Sil"
                                      data-confirm-variant="danger">
                                    <input type="hidden" name="userId" value="@user.Id" />
                                    <button type="submit" class="btn btn-ghost" style="font-size:12px; color:var(--danger);">
                                        Sil
                                    </button>
                                </form>
                            }
                            else
                            {
                                <span style="font-size:12px; color:var(--text-muted);">—</span>
                            }
                        </div>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

@section Scripts {
    <script>
        document.getElementById('userSearch').addEventListener('input', function() {
            var q = this.value.toLowerCase();
            document.querySelectorAll('#userTable tbody tr').forEach(function(row) {
                row.style.display = row.dataset.search.includes(q) ? '' : 'none';
            });
        });
    </script>
}
