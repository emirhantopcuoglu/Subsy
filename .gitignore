## Ignore Visual Studio temporary files, build results, and
## files generated by popular Visual Studio add-ons.

# User-specific files
*.suo
*.user
*.userosscache
*.sln.docstates

# Build results
[Dd]ebug/
[Rr]elease/
x64/
x86/
build/
bld/
[Bb]in/
[Oo]bj/

# Visual Studio files
.vs/
*.dbmdl
*.bak
*.log
*.ldf

# Rider
.idea/

# OS generated files
.DS_Store
Thumbs.db

# Entity Framework Migrations
Migrations/

# Others
*.db
*.sqlite
.env
